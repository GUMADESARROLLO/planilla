---
import AppLayout from "@components/layout/AppLayout.astro";
import Badge from "@components/ui/Badge.astro";
import Alert from "@components/ui/Alert.astro";
import * as permitsService from "@modules/permits/services/permits.service";
import type { EsquelaResponse } from "@modules/permits/types";
import { NotFoundError } from "@utils/errors";
import { getSession } from "@middleware/auth";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/permits");
}

let esquela: EsquelaResponse;
try {
  esquela = await permitsService.findById(id);
} catch (e) {
  if (e instanceof NotFoundError) {
    return Astro.redirect("/permits");
  }
  throw e;
}

const session = await getSession(Astro.request);
const canApprove = session && (session.user.role === "SUPERVISOR" || session.user.role === "ADMIN");
const isPending = esquela.estado === "pendiente";

function fmt(d: string): string {
  try {
    return new Date(d).toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" });
  } catch { return d; }
}

function fmtDT(d: string): string {
  try {
    return new Date(d).toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
  } catch { return d; }
}

function estadoBadge(estado: string): { color: string; label: string; dot: string } {
  switch (estado) {
    case "pendiente": return { color: "bg-amber-100 text-amber-700 border-amber-200", label: "Pendiente", dot: "bg-amber-500" };
    case "aprobada": return { color: "bg-emerald-100 text-emerald-700 border-emerald-200", label: "Aprobada", dot: "bg-emerald-500" };
    case "rechazada": return { color: "bg-red-100 text-red-700 border-red-200", label: "Rechazada", dot: "bg-red-500" };
    default: return { color: "bg-gray-100 text-gray-700 border-gray-200", label: estado, dot: "bg-gray-500" };
  }
}

const w = esquela.trabajador;
const badge = estadoBadge(esquela.estado);
const initials = w ? `${(w.nombre ?? "")[0] ?? ""}${(w.apellidos ?? "")[0] ?? ""}` : "??";
const fullName = w ? `${w.nombre} ${w.apellidos}` : "N/A";
const cargoText = esquela.cargo ?? w?.cargo ?? "N/A";
const ubicacionText = esquela.ubicacion;
---

<AppLayout title={`Esquela - ${fullName}`} currentPath="/permits">
  <div class="max-w-5xl mx-auto py-8 px-4">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <a href="/permits" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Volver">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight">Esquela de Permiso</h1>
          <p class="text-sm text-gray-400 mt-0.5">ID #{String(esquela.id)}</p>
        </div>
      </div>

      <div class="flex items-center gap-3">
        {isPending && canApprove && (
          <>
            <button id="btn-rechazar" type="button"
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold bg-red-600 text-white hover:bg-red-700 transition-colors shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              Rechazar
            </button>
            <button id="btn-aprobar" type="button"
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold bg-emerald-600 text-white hover:bg-emerald-700 transition-colors shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Aprobar
            </button>
          </>
        )}
        <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold border ${badge.color}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${badge.dot}`}></span>
          {badge.label}
        </span>
      </div>
    </div>

    <!-- Alerts -->
    {esquela.estado === "aprobada" && (
      <Alert variant="success" title="Permiso Aprobado" class="mb-6">
        Este permiso ha sido aprobado{esquela.nombreAprobador ? ` por ${esquela.nombreAprobador}` : ""}.
      </Alert>
    )}
    {esquela.estado === "rechazada" && (
      <Alert variant="error" title="Permiso Rechazado" class="mb-6">
        Este permiso ha sido rechazado{esquela.nombreAprobador ? ` por ${esquela.nombreAprobador}` : ""}.
      </Alert>
    )}
    <div id="action-error" class="hidden mb-6">
      <div class="p-3 rounded-lg bg-danger-50 dark:bg-danger-950 border border-danger-200 dark:border-danger-900 text-sm text-danger-700 dark:text-danger-400"></div>
    </div>

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-5">
      <!-- Worker card (3/5) -->
      <div class="md:col-span-3 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-7">
        <div class="flex items-center gap-4 mb-6 pb-6 border-b border-gray-100 dark:border-gray-800">
          <div class="w-12 h-12 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center shrink-0">
            <span class="text-lg font-bold text-indigo-600 dark:text-indigo-400">{initials}</span>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-0.5">Trabajador</p>
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">{fullName}</h2>
            <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{cargoText}</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-x-6 gap-y-5">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Cédula de identidad</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{w?.cedulaIdentidad ?? "-"}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Email</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate">{w?.email ?? "-"}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Teléfono</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{w?.telefono ?? "-"}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Ubicación</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{ubicacionText}</p>
          </div>
        </div>
      </div>

      <!-- Permit card (2/5) -->
      <div class="md:col-span-2 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-7 flex flex-col gap-5">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tipo de permiso</p>
          <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-indigo-50 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-800">
            {esquela.tipoPermiso?.nombre ?? "N/A"}
          </span>
          {esquela.tipoPermiso?.descripcion && (
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1.5">{esquela.tipoPermiso.descripcion}</p>
          )}
        </div>

        <div class="bg-indigo-50 dark:bg-indigo-900/30 rounded-xl px-4 py-3 border border-indigo-100 dark:border-indigo-800">
          <p class="text-xs font-semibold text-indigo-400 dark:text-indigo-300 uppercase tracking-wider mb-1">Duración</p>
          <p class="text-3xl font-extrabold text-indigo-700 dark:text-indigo-300 leading-none">
            {Number(esquela.cantidadDias ?? 0).toFixed(2)}
            <span class="text-lg font-semibold text-indigo-400 dark:text-indigo-400"> día(s)</span>
          </p>
        </div>

        <div class="grid grid-cols-2 gap-x-4 gap-y-4">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Fecha inicio</p>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">{fmt(esquela.fechaInicio)}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Fecha fin</p>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">{fmt(esquela.fechaFin)}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Incorporación</p>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">{fmt(esquela.fechaIncorporacion)}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Elaborado</p>
            <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">{fmtDT(esquela.fechaElaborada)}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Observaciones -->
    {esquela.observaciones && (
      <div class="mt-5 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-7">
        <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Observaciones</h3>
        <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap">{esquela.observaciones}</p>
      </div>
    )}

    <!-- Approval Info -->
    {(esquela.estado === "aprobada" || esquela.estado === "rechazada") && (
      <div class="mt-5 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-7">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Aprobado/Rechazado por</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{esquela.nombreAprobador ?? "N/A"}</p>
          </div>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Fecha y hora</p>
            <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{esquela.aprobadoEn ? fmtDT(esquela.aprobadoEn) : "-"}</p>
          </div>
          {esquela.firmaDigital && (
            <div class="md:col-span-2">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Firma Digital</p>
              <p class="text-sm text-gray-700 dark:text-gray-300 font-mono break-all bg-gray-50 dark:bg-gray-800 p-3 rounded-lg">{esquela.firmaDigital}</p>
            </div>
          )}
        </div>
      </div>
    )}

    {isPending && !canApprove && (
      <div class="mt-5 bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm p-7 text-center">
        <p class="text-sm text-gray-500 dark:text-gray-400">Este permiso está pendiente de aprobación por un supervisor o administrador.</p>
      </div>
    )}
  </div>
</AppLayout>

<script define:vars={{ esquelaId: id }}>
  void esquelaId;
  const btnAprobar = document.getElementById("btn-aprobar");
  const btnRechazar = document.getElementById("btn-rechazar");
  const errorDiv = document.getElementById("action-error");
  const errorMsg = errorDiv?.querySelector("div");

  function showError(message: string) {
    if (errorDiv && errorMsg) { errorMsg.textContent = message; errorDiv.classList.remove("hidden"); }
  }
  function hideError() { if (errorDiv) errorDiv.classList.add("hidden"); }

  function setLoading(button: HTMLElement | null, loading: boolean) {
    if (!button) return;
    if (loading) { button.setAttribute("disabled", "true"); button.innerHTML = '<svg class="animate-spin size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Procesando...'; }
    else { button.removeAttribute("disabled"); }
  }

  btnAprobar?.addEventListener("click", async () => {
    hideError(); setLoading(btnAprobar, true);
    try {
      const res = await fetch(`/api/permits/${esquelaId}/approve`, { method: "POST" });
      const json = await res.json();
      if (res.ok) window.location.reload();
      else showError(json?.error?.message || "Error al aprobar");
    } catch { showError("Error de conexión"); }
    finally { setLoading(btnAprobar, false); }
  });

  btnRechazar?.addEventListener("click", async () => {
    hideError(); setLoading(btnRechazar, true);
    try {
      const res = await fetch(`/api/permits/${esquelaId}/reject`, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({}) });
      const json = await res.json();
      if (res.ok) window.location.reload();
      else showError(json?.error?.message || "Error al rechazar");
    } catch { showError("Error de conexión"); }
    finally { setLoading(btnRechazar, false); }
  });
</script>

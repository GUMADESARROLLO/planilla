---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import Badge from "@components/ui/Badge.astro";
import Modal from "@components/ui/Modal.astro";
import FormField from "@components/ui/FormField.astro";
import DatePicker from "@components/ui/DatePicker.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import ConfirmDialog from "@components/shared/ConfirmDialog.astro";
import Pagination from "@components/shared/Pagination.astro";
import * as permitsService from "@modules/permits/services/permits.service";
import type { EsquelaResponse } from "@modules/permits/types";
import { db } from "@/db";
import { trabajadores } from "@/db/schemas/workers";
import { tiposPermisos, cargos, departamentos } from "@/db/schemas/catalogs";
import { eq, isNull } from "drizzle-orm";
import { Eye, Trash2 } from "@lucide/astro";

const currentUrl = Astro.url;

const page = parseInt(currentUrl.searchParams.get("page") ?? "1", 10);
const limit = 10;
const search = currentUrl.searchParams.get("search") ?? undefined;
const estado = currentUrl.searchParams.get("estado") ?? undefined;

const validEstados = ["pendiente", "aprobada", "rechazada"];
const estadoFilter = estado && validEstados.includes(estado)
  ? (estado as "pendiente" | "aprobada" | "rechazada")
  : undefined;

const result = await permitsService.findAll({
  page,
  limit,
  search,
  estado: estadoFilter,
});

const [workers, tipos, cargosList, deptosList] = await Promise.all([
  db
    .select({
      id: trabajadores.id,
      nombre: trabajadores.nombre,
      apellidos: trabajadores.apellidos,
      cedulaIdentidad: trabajadores.cedulaIdentidad,
      cargoId: trabajadores.cargoId,
    })
    .from(trabajadores)
    .where(isNull(trabajadores.deleted_at)),
  db
    .select({ id: tiposPermisos.id, nombre: tiposPermisos.nombre })
    .from(tiposPermisos),
  db
    .select({ id: cargos.id, nombre: cargos.nombre, departamentoId: cargos.departamentoId })
    .from(cargos)
    .where(isNull(cargos.deleted_at)),
  db
    .select({ id: departamentos.id, nombre: departamentos.nombre })
    .from(departamentos)
    .where(isNull(departamentos.deleted_at)),
]);

function formatDate(d: string): string {
  try {
    return new Date(d).toLocaleDateString("es-ES");
  } catch {
    return d;
  }
}

function estadoVariant(estado: string): string {
  switch (estado) {
    case "pendiente": return "warning";
    case "aprobada": return "success";
    case "rechazada": return "danger";
    default: return "default";
  }
}

function estadoLabel(estado: string): string {
  switch (estado) {
    case "pendiente": return "Pendiente";
    case "aprobada": return "Aprobada";
    case "rechazada": return "Rechazada";
    default: return estado;
  }
}

const tabs = [
  { label: "Todas", href: "/permits", active: !estado },
  { label: "Pendientes", href: "/permits?estado=pendiente", active: estado === "pendiente" },
  { label: "Aprobadas", href: "/permits?estado=aprobada", active: estado === "aprobada" },
  { label: "Rechazadas", href: "/permits?estado=rechazada", active: estado === "rechazada" },
];
---

<AppLayout title="Esquelas de Permisos" currentPath="/permits">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Esquelas de Permisos</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Gestión de esquelas de permisos del personal
      </p>
    </div>
    <Button id="btn-nueva-esquela" variant="primary">
      <span slot="icon">
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </span>
      Nueva Esquela
    </Button>
  </div>

  <!-- Search + Tabs row -->
  <div class="mb-4 flex items-center gap-3 flex-wrap">
    <form method="GET" action="/permits" class="flex items-center gap-2 flex-1 min-w-0">
      <input type="hidden" name="estado" value={estado ?? ""} />
      <div class="relative flex-1 min-w-[180px] max-w-xs">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="text" name="search" value={search ?? ""} placeholder="Buscar por nombre..."
          class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        />
      </div>
      <button type="submit" class="px-3 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors shrink-0">Buscar</button>
      {search && (
        <a href={estado ? `/permits?estado=${estado}` : "/permits"} class="px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shrink-0">Limpiar</a>
      )}
    </form>

    <!-- Filter Tabs -->
    <div class="flex gap-1 p-1 bg-gray-100 dark:bg-gray-800 rounded-lg shrink-0">
      {tabs.map((tab) => (
        <a
          href={tab.href}
          class:list={[
            "px-4 py-2 text-sm font-medium rounded-md transition-colors whitespace-nowrap",
            tab.active
              ? "bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow-sm"
              : "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-white/50 dark:hover:bg-gray-700/50",
          ]}
        >
          {tab.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Table -->
  {result.data.length === 0 ? (
    <EmptyState title="Sin esquelas de permisos" description={search || estado ? "No se encontraron resultados con los filtros aplicados." : "No hay esquelas de permisos registradas."} />
  ) : (
    <>
      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trabajador</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tipo Permiso</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Fecha</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Días</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Estado</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
            {result.data.map((esquela) => (
              <tr
                class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
                data-id={esquela.id}
              >
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {esquela.trabajador
                    ? `${esquela.trabajador.nombre} ${esquela.trabajador.apellidos}`
                    : "N/A"}
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {esquela.tipoPermiso?.nombre ?? "N/A"}
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {formatDate(esquela.fechaElaborada)}
                </td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                    {Number(esquela.cantidadDias ?? 0).toFixed(2)}
                  </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <Badge variant={estadoVariant(esquela.estado)}>
                    {estadoLabel(esquela.estado)}
                  </Badge>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-1">
                    <a
                      href={`/permits/${esquela.id}`}
                      class="p-1.5 rounded-lg text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-950/50 transition-colors"
                      aria-label="Ver detalle"
                    >
                      <Eye class="size-4" />
                    </a>
                    <button
                      data-delete-id={esquela.id}
                      data-delete-name={`${esquela.trabajador?.nombre ?? ""} ${esquela.trabajador?.apellidos ?? ""}`}
                      class="btn-delete p-1.5 rounded-lg text-gray-400 hover:text-danger-600 hover:bg-danger-50 dark:hover:text-danger-400 dark:hover:bg-danger-950/50 transition-colors"
                      aria-label="Eliminar esquela"
                      type="button"
                    >
                      <Trash2 class="size-4" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <Pagination
          page={result.page}
          totalPages={result.totalPages}
          total={result.total}
          limit={result.limit}
          baseUrl={currentUrl.pathname + (estado ? `?estado=${estado}` : "") + ((estado && search) ? `&search=${search}` : search ? `?search=${search}` : "")}
        />
      </div>
    </>
  )}

  <!-- Delete Confirm Dialog -->
  <ConfirmDialog
    id="confirm-delete"
    title="Eliminar Esquela de Permiso"
    message="¿Estás seguro de que deseas eliminar esta esquela? Esta acción no se puede deshacer."
    confirmText="Eliminar"
    cancelText="Cancelar"
    variant="danger"
  />
</AppLayout>

<!-- Create Modal -->
<Modal id="create-modal" title="Nueva Esquela de Permiso" size="lg">
  <div slot="body">
    <form id="create-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2">
        <FormField label="Trabajador" name="trabajadorId" required>
          <select
            id="field-trabajadorId"
            name="trabajadorId"
            required
            class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
          >
            <option value="">Seleccione un trabajador...</option>
            {workers.map((w) => (
              <option value={w.id}>{w.nombre} {w.apellidos} - {w.cedulaIdentidad}</option>
            ))}
          </select>
        </FormField>
      </div>

      <FormField label="Tipo de Permiso" name="tipoPermisoId" required>
        <select
          id="field-tipoPermisoId"
          name="tipoPermisoId"
          required
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
        >
          <option value="">Seleccione un tipo...</option>
          {tipos.map((tp) => (
            <option value={tp.id}>{tp.nombre}</option>
          ))}
        </select>
      </FormField>

      <FormField label="Cantidad de Días" name="cantidadDias" required>
        <input
          id="field-cantidadDias"
          name="cantidadDias"
          type="text"
          inputmode="decimal"
          required
          placeholder="Ej: 5.0"
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
        />
      </FormField>

      <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-4">
        <FormField label="Fecha de Inicio" name="fechaInicio" required>
          <DatePicker id="field-fechaInicio" name="fechaInicio" required />
        </FormField>
        <FormField label="Fecha de Fin" name="fechaFin" required>
          <DatePicker id="field-fechaFin" name="fechaFin" required />
        </FormField>
        <FormField label="Fecha de Incorporación" name="fechaIncorporacion" required>
          <DatePicker id="field-fechaIncorporacion" name="fechaIncorporacion" required />
        </FormField>
      </div>

      <FormField label="Cargo" name="cargo" required>
        <select
          id="field-cargo"
          name="cargo"
          required
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
        >
          <option value="">Seleccione cargo...</option>
          {cargosList.map((c) => (
            <option value={c.nombre}>{c.nombre}</option>
          ))}
        </select>
      </FormField>

      <FormField label="Ubicación" name="ubicacion" required>
        <select
          id="field-ubicacion"
          name="ubicacion"
          required
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
        >
          <option value="">Seleccione ubicación...</option>
          {deptosList.map((d) => (
            <option value={d.nombre}>{d.nombre}</option>
          ))}
        </select>
      </FormField>

      <div class="md:col-span-2">
        <FormField label="Observaciones" name="observaciones">
          <textarea
            id="field-observaciones"
            name="observaciones"
            rows="3"
            placeholder="Observaciones adicionales (opcional)"
            class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 resize-none"
          ></textarea>
        </FormField>
      </div>

      <div id="create-form-error" class="md:col-span-2 hidden">
        <div class="p-3 rounded-lg bg-danger-50 dark:bg-danger-950 border border-danger-200 dark:border-danger-900 text-sm text-danger-700 dark:text-danger-400"></div>
      </div>
    </form>
  </div>
  <div slot="footer">
    <button
      type="button"
      id="create-cancel"
      class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
    >
      Cancelar
    </button>
    <button
      type="button"
      id="create-submit"
      class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors"
    >
      Guardar Esquela
    </button>
  </div>
</Modal>

<textarea id="cargos-data" class="hidden" set:html={JSON.stringify(cargosList)}></textarea>
<textarea id="workers-data" class="hidden" set:html={JSON.stringify(workers.map(w => ({ id: w.id, cargoId: w.cargoId })))}></textarea>
<textarea id="deptos-data" class="hidden" set:html={JSON.stringify(deptosList)}></textarea>

<script>
  const cargosListClient: Array<{id: number; nombre: string; departamentoId: number | null}> = JSON.parse((document.getElementById("cargos-data") as HTMLTextAreaElement)?.value ?? "[]");
  const deptosListClient: Array<{id: number; nombre: string}> = JSON.parse((document.getElementById("deptos-data") as HTMLTextAreaElement)?.value ?? "[]");
  const workersCargoMap: Record<number, number | null> = {};
  JSON.parse((document.getElementById("workers-data") as HTMLTextAreaElement)?.value ?? "[]").forEach((w: any) => { workersCargoMap[w.id] = w.cargoId ?? null; });
  const cargoIdToName: Record<number, string> = {};
  const deptoIdToName: Record<number, string> = {};
  const cargoIdToDeptoName: Record<number, string> = {};
  cargosListClient.forEach((c) => {
    cargoIdToName[c.id] = c.nombre;
    if (c.departamentoId) {
      const depto = deptosListClient.find(d => d.id === c.departamentoId);
      if (depto) cargoIdToDeptoName[c.id] = depto.nombre;
    }
  });
  deptosListClient.forEach((d) => { deptoIdToName[d.id] = d.nombre; });

  import Swal from "sweetalert2";

  // Inputmask for decimal number input
  import $ from "jquery";
  import "inputmask";
  $(document).ready(() => {
    $("#field-cantidadDias").inputmask({
      alias: "decimal",
      digits: 2,
      digitsOptional: true,
      min: 0,
      groupSeparator: "",
      autoGroup: false,
      rightAlign: false,
      allowMinus: false,
      placeholder: "0",
    });
  });

  const btnNueva = document.getElementById("btn-nueva-esquela");
  const modalOverlay = document.querySelector("#\\#create-modal");
  const cancelBtn = document.getElementById("create-cancel");
  const submitBtn = document.getElementById("create-submit");
  const form = document.getElementById("create-form") as HTMLFormElement;
  const errorDiv = document.getElementById("create-form-error");
  const errorMsg = errorDiv?.querySelector("div");

  function openModal() {
    (window as any).__openModal?.();
  }

  function closeModal() {
    form.reset();
    if (errorDiv) errorDiv.classList.add("hidden");
    (window as any).__closeModal?.();
  }

  btnNueva?.addEventListener("click", openModal);
  cancelBtn?.addEventListener("click", closeModal);

  // Auto-populate cargo + ubicacion when worker is selected
  const workerSelect = document.getElementById("field-trabajadorId") as HTMLSelectElement | null;
  const cargoSelect = document.getElementById("field-cargo") as HTMLSelectElement | null;
  const ubicacionSelect = document.getElementById("field-ubicacion") as HTMLSelectElement | null;
  workerSelect?.addEventListener("change", () => {
    const workerId = Number(workerSelect.value);
    const cargoId = workersCargoMap[workerId] ?? null;
    if (cargoSelect && cargoId && cargoIdToName[cargoId]) {
      cargoSelect.value = cargoIdToName[cargoId];
    } else if (cargoSelect) {
      cargoSelect.value = "";
    }
    if (ubicacionSelect && cargoId && cargoIdToDeptoName[cargoId]) {
      ubicacionSelect.value = cargoIdToDeptoName[cargoId];
    } else if (ubicacionSelect) {
      ubicacionSelect.value = "";
    }
  });

  submitBtn?.addEventListener("click", async () => {
    if (!form) return;

    const formData = new FormData(form);
    const payload = {
      trabajadorId: Number(formData.get("trabajadorId")),
      cargo: formData.get("cargo") || undefined,
      ubicacion: formData.get("ubicacion") as string,
      tipoPermisoId: Number(formData.get("tipoPermisoId")),
      cantidadDias: parseFloat(formData.get("cantidadDias") as string),
      fechaInicio: formData.get("fechaInicio"),
      fechaFin: formData.get("fechaFin"),
      fechaIncorporacion: formData.get("fechaIncorporacion"),
      observaciones: formData.get("observaciones") || undefined,
    };

    if (!payload.trabajadorId || !payload.tipoPermisoId || !payload.ubicacion || !payload.cantidadDias || !payload.fechaInicio || !payload.fechaFin || !payload.fechaIncorporacion) {
      if (errorDiv && errorMsg) {
        errorMsg.textContent = "Todos los campos marcados con * son requeridos.";
        errorDiv.classList.remove("hidden");
      }
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Guardando...";

    try {
      const res = await fetch("/api/permits", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const json = await res.json();

      if (res.ok) {
        closeModal();
        window.location.reload();
      } else {
        if (errorDiv && errorMsg) {
          errorMsg.textContent = json?.error?.message || "Error al crear la esquela";
          errorDiv.classList.remove("hidden");
        }
      }
    } catch {
      if (errorDiv && errorMsg) {
        errorMsg.textContent = "Error de conexión. Intente nuevamente.";
        errorDiv.classList.remove("hidden");
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Guardar Esquela";
    }
  });

  // ---- Delete ----
  let deleteTargetId: string | null = null;

  document.querySelectorAll(".btn-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      deleteTargetId = btn.getAttribute("data-delete-id");
      const name = btn.getAttribute("data-delete-name") ?? "esta esquela";
      const msgEl = document.querySelector("#confirm-delete #confirm-message");
      if (msgEl) msgEl.textContent = `¿Estás seguro de eliminar la esquela de "${name}"?`;
      (window as any).__openConfirm?.();
    });
  });

  document.addEventListener("confirm-ok", async () => {
    if (!deleteTargetId) return;
    try {
      const res = await fetch(`/api/permits/${deleteTargetId}`, { method: "DELETE" });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message ?? "Error al eliminar");
      window.location.reload();
    } catch (err: any) {
      Swal.fire("Error", err.message, "error");
    }
    deleteTargetId = null;
  });

  document.addEventListener("confirm-cancel", () => { deleteTargetId = null; });
</script>

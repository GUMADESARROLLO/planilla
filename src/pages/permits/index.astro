---
import AppLayout from "@components/layout/AppLayout.astro";
import Badge from "@components/ui/Badge.astro";
import DatePicker from "@components/ui/DatePicker.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import ConfirmDialog from "@components/shared/ConfirmDialog.astro";
import Pagination from "@components/shared/Pagination.astro";
import * as permitsService from "@modules/permits/services/permits.service";
import { db } from "@/db";
import { tiposPermisos } from "@/db/schemas/catalogs";
import { Eye, Trash2 } from "@lucide/astro";

const currentUrl = Astro.url;

const page = parseInt(currentUrl.searchParams.get("page") ?? "1", 10);
const limit = 10;
const search = currentUrl.searchParams.get("search") ?? undefined;
const estado = currentUrl.searchParams.get("estado") ?? undefined;
const tipoPermisoId = currentUrl.searchParams.get("tipo_permiso_id")
  ? Number(currentUrl.searchParams.get("tipo_permiso_id"))
  : undefined;
const fechaDesde = currentUrl.searchParams.get("fecha_desde") ?? undefined;
const fechaHasta = currentUrl.searchParams.get("fecha_hasta") ?? undefined;

const validEstados = ["pendiente", "aprobada", "rechazada"];
const estadoFilter = estado && validEstados.includes(estado)
  ? (estado as "pendiente" | "aprobada" | "rechazada")
  : undefined;

const result = await permitsService.findAll({
  page,
  limit,
  search,
  estado: estadoFilter,
  tipoPermisoId,
  fechaDesde,
  fechaHasta,
});

const tipos = await db
  .select({ id: tiposPermisos.id, nombre: tiposPermisos.nombre })
  .from(tiposPermisos);

function formatDate(d: string): string {
  try { return new Date(d).toLocaleDateString("es-ES"); } catch { return d; }
}

function estadoVariant(estado: string): string {
  switch (estado) {
    case "pendiente": return "warning";
    case "aprobada": return "success";
    case "rechazada": return "danger";
    default: return "default";
  }
}

function estadoLabel(estado: string): string {
  switch (estado) {
    case "pendiente": return "Pendiente";
    case "aprobada": return "Aprobada";
    case "rechazada": return "Rechazada";
    default: return estado;
  }
}
---

<AppLayout title="Esquelas de Permisos" currentPath="/permits">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Esquelas de Permisos</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Gestión de esquelas de permisos del personal
      </p>
    </div>
  </div>

  <!-- Search + Filters row -->
  <div class="mb-4">
    <form method="GET" action="/permits" class="flex items-center gap-3" id="filter-form">
      <input type="hidden" name="estado" value={estado ?? ""} />
      <div class="relative flex-1 max-w-xs">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="text" name="search" value={search ?? ""} placeholder="Buscar..."
          class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        />
      </div>
      <div class="flex items-center gap-2 ml-auto">
        <DatePicker name="fecha_desde" value={fechaDesde ?? ""} placeholder="Fecha inicio" />
        <DatePicker name="fecha_hasta" value={fechaHasta ?? ""} placeholder="Fecha fin" />
        <select name="tipo_permiso_id"
        class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-colors"
      >
        <option value="">Todos</option>
        {tipos.map((tp) => (
          <option value={tp.id} selected={tipoPermisoId === tp.id}>{tp.nombre}</option>
        ))}
      </select>
      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors shrink-0">Filtrar</button>
      {(search || tipoPermisoId || fechaDesde || fechaHasta) && (
        <a href={estado ? `/permits?estado=${estado}` : "/permits"} class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shrink-0">Limpiar</a>
      )}
      </div>
    </form>
  </div>

  <!-- Table -->
  {result.data.length === 0 ? (
    <EmptyState title="Sin esquelas de permisos" description={search || estado ? "No se encontraron resultados con los filtros aplicados." : "No hay esquelas de permisos registradas."} />
  ) : (
    <>
      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trabajador</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tipo Permiso</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Fecha</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Días</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Estado</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
            {result.data.map((esquela) => (
              <tr
                class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
                data-id={esquela.id}
              >
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {esquela.trabajador
                    ? `${esquela.trabajador.nombre} ${esquela.trabajador.apellidos}`
                    : "N/A"}
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {esquela.tipoPermiso?.nombre ?? "N/A"}
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {formatDate(esquela.fechaElaborada)}
                </td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                    {Number(esquela.cantidadDias ?? 0).toFixed(2)}
                  </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <Badge variant={estadoVariant(esquela.estado)}>
                    {estadoLabel(esquela.estado)}
                  </Badge>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-1">
                    <a
                      href={`/permits/${esquela.id}`}
                      class="p-1.5 rounded-lg text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-950/50 transition-colors"
                      aria-label="Ver detalle"
                    >
                      <Eye class="size-4" />
                    </a>
                    <button
                      data-delete-id={esquela.id}
                      data-delete-name={`${esquela.trabajador?.nombre ?? ""} ${esquela.trabajador?.apellidos ?? ""}`}
                      class="btn-delete p-1.5 rounded-lg text-gray-400 hover:text-danger-600 hover:bg-danger-50 dark:hover:text-danger-400 dark:hover:bg-danger-950/50 transition-colors"
                      aria-label="Eliminar esquela"
                      type="button"
                    >
                      <Trash2 class="size-4" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <Pagination
          page={result.page}
          totalPages={result.totalPages}
          total={result.total}
          limit={result.limit}
          baseUrl={currentUrl.pathname
            + (estado ? `?estado=${estado}` : "?")
            + (search ? `${estado ? "&" : ""}search=${search}` : "")
            + (tipoPermisoId ? `${(estado || search) ? "&" : "?"}tipo_permiso_id=${tipoPermisoId}` : "")
            + (fechaDesde ? `${(estado || search || tipoPermisoId) ? "&" : "?"}fecha_desde=${fechaDesde}` : "")
            + (fechaHasta ? `${(estado || search || tipoPermisoId || fechaDesde) ? "&" : "?"}fecha_hasta=${fechaHasta}` : "")}
        />
      </div>
    </>
  )}

  <!-- Delete Confirm Dialog -->
  <ConfirmDialog
    id="confirm-delete"
    title="Eliminar Esquela de Permiso"
    message="¿Estás seguro de que deseas eliminar esta esquela? Esta acción no se puede deshacer."
    confirmText="Eliminar"
    cancelText="Cancelar"
    variant="danger"
  />
</AppLayout>

<script>
  import Swal from "sweetalert2";

  let deleteTargetId: string | null = null;

  document.querySelectorAll(".btn-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      deleteTargetId = btn.getAttribute("data-delete-id");
      const name = btn.getAttribute("data-delete-name") ?? "esta esquela";
      const msgEl = document.querySelector("#confirm-delete #confirm-message");
      if (msgEl) msgEl.textContent = `¿Estás seguro de eliminar la esquela de "${name}"?`;
      (window as any).__openConfirm?.();
    });
  });

  document.addEventListener("confirm-ok", async () => {
    if (!deleteTargetId) return;
    try {
      const res = await fetch(`/api/permits/${deleteTargetId}`, { method: "DELETE" });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message ?? "Error al eliminar");
      window.location.reload();
    } catch (err: any) {
      Swal.fire("Error", err.message, "error");
    }
    deleteTargetId = null;
  });

  document.addEventListener("confirm-cancel", () => { deleteTargetId = null; });
</script>

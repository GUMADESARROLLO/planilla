---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import Modal from "@components/ui/Modal.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import { ArrowLeft, Plus } from "@lucide/astro";
import * as payrollService from "@modules/payrolls/services/payroll.service";
import { requireAuth } from "@middleware/auth";

await requireAuth(Astro);

const { id } = Astro.params;
if (!id) return Astro.redirect("/payrolls");

const payrollId = Number(id);
let planilla: any;
try {
  planilla = await payrollService.findById(payrollId);
} catch {
  return Astro.redirect("/payrolls");
}

const currentPath = "/payrolls";
const workers = planilla.workers ?? [];

function fmtPeriodo(d: Date | string | null | undefined): string {
  if (!d) return "—";
  try { return new Date(d).toLocaleDateString("es-ES", { day: "2-digit", month: "long", year: "numeric" }); }
  catch { return "—"; }
}

const periodoDesde = fmtPeriodo(planilla.fechaDesde);
const periodoHasta = fmtPeriodo(planilla.fechaHasta);
const title = planilla.nombre + (planilla.fechaDesde ? ` (${periodoDesde} → ${periodoHasta})` : "");

function fmtFecha(d: Date | string | null | undefined): string {
  if (!d) return "-";
  try { return new Date(d).toLocaleDateString("es-ES", { day: "2-digit", month: "2-digit", year: "numeric" }); }
  catch { return "-"; }
}

function fmtSal(sal: any): string {
  if (sal === null || sal === undefined || sal === "") return "0.00";
  const n = typeof sal === "string" ? parseFloat(sal) : Number(sal);
  return isNaN(n) ? "0.00" : n.toFixed(2);
}
---

<AppLayout {title} {currentPath}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-3 flex-1">
        <a href="/payrolls" class="p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 transition-colors shrink-0" aria-label="Volver">
          <ArrowLeft class="size-5" />
        </a>
        <div class="relative flex-1 max-w-sm">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input id="worker-filter-input" type="text" placeholder="Buscar por nombre, cargo, cédula..." class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
        </div>
      </div>
      <Button id="btn-add-worker" variant="primary" size="sm" class="shrink-0">
        <Plus class="size-4" slot="icon" />
        Agregar Trabajador
      </Button>
    </div>

    <!-- Workers Table -->
    <Card title="Trabajadores Asignados">
      {workers.length === 0 ? (
        <EmptyState title="Sin trabajadores asignados" description="Agrega trabajadores a esta planilla usando el botón superior." />
      ) : (
        <div slot="body" class="-mx-6 overflow-x-auto border-t border-gray-200 dark:border-gray-700">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700" style="min-width:2400px">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Nº</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Nombres y Apellidos</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Cargo</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Cédula</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Nº INSS</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Fch. Ingreso</th>
                <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Nº Cuenta</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Sal. Mensual</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Días LAB</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Sal. ORD</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Hrs Extras</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Hrs Extras Monto</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Días Vac Descans</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Días Vac Descans Monto</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Ingreso Gravables</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Ingreso No Gravables</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">DÍA SUB. MATERN</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">SUB. MATERNIDAD</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">SUB. ESTATAL</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Total Ingreso</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Hrs. A Deducir</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Monto Hrs. a Deducir</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">INSS Cotiz. Lab</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">IR</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Deduc. Varias</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Total Deducir</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">Neto a Pagar</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">INSS Patronal</th>
                <th class="px-3 py-2.5 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">INATEC</th>
              </tr>
            </thead>
            <tbody id="workers-tbody" class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
              {workers.map((w: any, i: number) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors" data-search={`${w.nombre} ${w.apellidos} ${w.cargo || ""} ${w.cedulaIdentidad || ""} ${w.numeroInss || ""}`.toLowerCase()}>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{i + 1}</td>
                  <td class="px-3 py-2 text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap">{w.nombre} {w.apellidos}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{w.cargo || "-"}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{w.cedulaIdentidad || "-"}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{w.numeroInss || "-"}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{fmtFecha(w.fechaEntrada)}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">{w.cuentaNomina || "-"}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">{fmtSal(w.salarioBase)}</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm font-bold text-gray-900 dark:text-white whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                  <td class="px-3 py-2 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap text-right">0.00</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      <div slot="footer" class="flex items-center justify-between px-6 py-3 border-t border-gray-200 dark:border-gray-700">
        <span id="table-info" class="text-sm text-gray-500 dark:text-gray-400"></span>
        <div class="flex items-center gap-2">
          <button id="btn-prev" class="px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors" disabled>Anterior</button>
          <span id="page-info" class="text-sm text-gray-600 dark:text-gray-400 px-2"></span>
          <button id="btn-next" class="px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">Siguiente</button>
        </div>
      </div>
    </Card>
  </div>

  <input id="page-data-payroll" type="hidden" data-id={payrollId} data-workers={JSON.stringify(workers.map((w: any) => ({ id: w.id, nombre: w.nombre, apellidos: w.apellidos, email: w.email, cargo: w.cargo })))} />

  <!-- Add Worker Modal -->
  <Modal open={false} title="Agregar Trabajador" size="lg">
    <div slot="body" class="space-y-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input id="worker-search-input" type="text" placeholder="Buscar trabajadores por nombre o email..." class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors" />
      </div>
      <div id="worker-search-results" class="max-h-64 overflow-y-auto space-y-1">
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe para buscar trabajadores</p>
      </div>
    </div>
    <div slot="footer">
      <button id="btn-add-worker-cancel" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">Cerrar</button>
    </div>
  </Modal>
</AppLayout>

<script>
  const ROWS_PER_PAGE = 20;
  let currentPage = 1;
  let currentQuery = "";

  const tbody = document.getElementById("workers-tbody") as HTMLElement;
  const filterInput = document.getElementById("worker-filter-input") as HTMLInputElement;
  const tableInfo = document.getElementById("table-info") as HTMLElement;
  const pageInfo = document.getElementById("page-info") as HTMLElement;
  const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
  const btnNext = document.getElementById("btn-next") as HTMLButtonElement;

  function getRows(): HTMLElement[] {
    return Array.from(tbody.querySelectorAll("tr"));
  }

  function getFilteredRows(): HTMLElement[] {
    const q = currentQuery.toLowerCase().trim();
    return getRows().filter((row) => {
      if (!q) return true;
      return (row.getAttribute("data-search") || "").includes(q);
    });
  }

  function render() {
    const allRows = getRows();
    const filtered = getFilteredRows();
    const totalPages = Math.max(1, Math.ceil(filtered.length / ROWS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * ROWS_PER_PAGE;
    const end = start + ROWS_PER_PAGE;
    const pageRows = filtered.slice(start, end);

    allRows.forEach((row) => (row.style.display = "none"));
    pageRows.forEach((row) => (row.style.display = ""));

    const total = allRows.length;
    tableInfo.textContent = currentQuery
      ? `${filtered.length} de ${total} trabajadores`
      : `${total} trabajadores`;

    pageInfo.textContent = `Página ${currentPage} de ${totalPages}`;
    btnPrev.disabled = currentPage <= 1;
    btnNext.disabled = currentPage >= totalPages;
  }

  filterInput?.addEventListener("input", () => {
    currentQuery = filterInput.value;
    currentPage = 1;
    render();
  });

  btnPrev?.addEventListener("click", () => {
    if (currentPage > 1) { currentPage--; render(); }
  });

  btnNext?.addEventListener("click", () => {
    const filtered = getFilteredRows();
    const totalPages = Math.ceil(filtered.length / ROWS_PER_PAGE);
    if (currentPage < totalPages) { currentPage++; render(); }
  });

  render();

  // --- Worker search modal (unchanged) ---
  const payrollEl = document.getElementById("page-data-payroll") as HTMLInputElement;
  const payrollId = Number(payrollEl?.getAttribute("data-id"));
  let workersList: any[] = [];
  try { workersList = JSON.parse(payrollEl?.getAttribute("data-workers") ?? "[]"); } catch {}

  document.getElementById("btn-add-worker")?.addEventListener("click", () => {
    (window as any).__openModal();
    const searchInput = document.getElementById("worker-search-input") as HTMLInputElement;
    searchInput.value = "";
    document.getElementById("worker-search-results")!.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe para buscar trabajadores</p>';
    searchInput.focus();
  });

  document.getElementById("btn-add-worker-cancel")?.addEventListener("click", () => {
    (window as any).__closeModal();
  });

  const workerSearchInput = document.getElementById("worker-search-input") as HTMLInputElement;
  let searchTimeout: ReturnType<typeof setTimeout>;

  workerSearchInput?.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    const query = workerSearchInput.value.trim();
    if (query.length < 2) {
      document.getElementById("worker-search-results")!.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe al menos 2 caracteres para buscar</p>';
      return;
    }
    searchTimeout = setTimeout(() => searchWorkers(query), 300);
  });

  async function searchWorkers(query: string) {
    const resultsContainer = document.getElementById("worker-search-results")!;
    resultsContainer.innerHTML = '<p class="text-sm text-gray-400 text-center py-4">Buscando...</p>';
    try {
      const res = await fetch(`/api/workers?search=${encodeURIComponent(query)}&limit=20`);
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message);
      const available = json.data.filter((w: any) => !workersList.some((aw: any) => aw.id === w.id));
      if (available.length === 0) {
        resultsContainer.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">No se encontraron trabajadores disponibles</p>';
        return;
      }
      resultsContainer.innerHTML = available.map((w: any) => `
        <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 dark:text-white truncate">${escapeHtml(w.nombre)} ${escapeHtml(w.apellidos)}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">${escapeHtml(w.email)} - ${escapeHtml(w.cargo || "Sin cargo")}</p>
          </div>
          <button data-assign-worker="${w.id}" class="shrink-0 px-3 py-1.5 text-xs font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">Asignar</button>
        </div>
      `).join("");
      document.querySelectorAll("[data-assign-worker]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const trabajadorId = btn.getAttribute("data-assign-worker")!;
          try {
            const res = await fetch(`/api/payrolls/${payrollId}/workers`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ trabajador_id: trabajadorId }),
            });
            const json = await res.json();
            if (!json.success) throw new Error(json.error?.message || "Error al asignar");
            window.location.reload();
          } catch (err) {
            alert(err instanceof Error ? err.message : "Error al asignar");
          }
        });
      });
    } catch {
      resultsContainer.innerHTML = '<p class="text-sm text-danger-500 text-center py-4">Error al buscar trabajadores</p>';
    }
  }

  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }
</script>
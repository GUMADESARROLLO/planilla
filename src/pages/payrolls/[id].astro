---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";
import Modal from "@components/ui/Modal.astro";
import Alert from "@components/ui/Alert.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import ConfirmDialog from "@components/shared/ConfirmDialog.astro";
import { ArrowLeft, Plus, Trash2 } from "@lucide/astro";

const title = "Detalle de Planilla";
const currentPath = "/payrolls";
---

<AppLayout {title} {currentPath}>
  <div id="alert-area" class="mb-4"></div>

  <div id="page-content" class="space-y-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/payrolls" class="p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 transition-colors" aria-label="Volver">
          <ArrowLeft class="size-5" />
        </a>
        <div>
          <h1 id="payroll-title" class="text-2xl font-bold text-gray-900 dark:text-white">Cargando...</h1>
          <p id="payroll-subtitle" class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">Cargando información de la planilla</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <Button id="btn-add-worker" variant="primary" size="sm">
          <Plus class="size-4" slot="icon" />
          Agregar Trabajador
        </Button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Card title="Información General" padding={true}>
        <div slot="body" class="space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500 dark:text-gray-400">Nombre</span>
            <span id="info-nombre" class="font-medium text-gray-900 dark:text-white">-</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500 dark:text-gray-400">Tipo</span>
            <span id="info-tipo" class="font-medium">-</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500 dark:text-gray-400">Estado</span>
            <span id="info-activo">-</span>
          </div>
        </div>
      </Card>
      <Card title="Descripción" padding={true}>
        <p id="info-descripcion" class="text-sm text-gray-600 dark:text-gray-400">-</p>
      </Card>
      <Card title="Trabajadores" padding={true}>
        <div slot="body" class="space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500 dark:text-gray-400">Asignados</span>
            <span id="info-workers-count" class="font-medium text-gray-900 dark:text-white">0</span>
          </div>
        </div>
      </Card>
    </div>

    <Card title="Trabajadores Asignados">
      <div slot="body" id="workers-table-container">
        <div class="flex items-center justify-center py-8">
          <div class="flex flex-col items-center gap-2">
            <div class="size-8 border-2 border-primary-600 border-t-transparent rounded-full animate-spin"></div>
            <p class="text-sm text-gray-500">Cargando trabajadores...</p>
          </div>
        </div>
      </div>
    </Card>
  </div>

  <Modal open={false} title="Agregar Trabajador" size="lg">
    <div slot="body" class="space-y-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input
          id="worker-search-input"
          type="text"
          placeholder="Buscar trabajadores por nombre o email..."
          class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        />
      </div>
      <div id="worker-search-results" class="max-h-64 overflow-y-auto space-y-1">
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe para buscar trabajadores</p>
      </div>
    </div>
    <div slot="footer">
      <button
        id="btn-add-worker-cancel"
        type="button"
        class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
      >
        Cerrar
      </button>
    </div>
  </Modal>

  <ConfirmDialog
    open={false}
    title="Remover Trabajador"
    message="¿Estás seguro de que deseas remover este trabajador de la planilla?"
    confirmText="Remover"
    cancelText="Cancelar"
    variant="danger"
  />
</AppLayout>

<script>
  const payrollId = window.location.pathname.split("/").pop()!;
  let workersList: any[] = [];
  let removeWorkerId: string | null = null;

  const alertArea = document.getElementById("alert-area")!;

  function showAlert(message: string, variant: "success" | "error" = "success") {
    alertArea.innerHTML = `
      <div class="flex gap-3 p-4 rounded-lg border ${
        variant === "success"
          ? "bg-success-50 border-success-200 dark:bg-success-950 dark:border-success-900"
          : "bg-danger-50 border-danger-200 dark:bg-danger-950 dark:border-danger-900"
      }" role="alert">
        <div class="flex-1 min-w-0">
          <p class="text-sm text-gray-700 dark:text-gray-300">${message}</p>
        </div>
        <button onclick="this.parentElement.remove()" class="p-1 rounded-md text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    `;
    setTimeout(() => { alertArea.innerHTML = ""; }, 5000);
  }

  function getTipoLabel(tipo: string): string {
    const map: Record<string, string> = { quincenal: "Quincenal", mensual: "Mensual", vehicular: "Vehicular", administrativa: "Administrativa", temporal: "Temporal" };
    return map[tipo] ?? tipo;
  }

  async function loadPayroll() {
    try {
      const res = await fetch(`/api/payrolls/${payrollId}`);
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message || "Error al cargar");

      const planilla = json.data;
      renderPayroll(planilla);
    } catch (err) {
      document.getElementById("page-content")!.innerHTML = `
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <svg class="size-12 text-gray-300 dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
          </svg>
          <h3 class="mt-4 text-base font-semibold text-gray-900 dark:text-white">Error al cargar</h3>
          <p class="mt-1 text-sm text-gray-500">${err instanceof Error ? err.message : "Error desconocido"}</p>
          <a href="/payrolls" class="mt-4 inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">Volver a planillas</a>
        </div>
      `;
    }
  }

  function renderPayroll(planilla: any) {
    document.getElementById("payroll-title")!.textContent = planilla.nombre;
    document.getElementById("payroll-subtitle")!.textContent = `Planilla ${getTipoLabel(planilla.tipo).toLowerCase()} - Creada ${new Date(planilla.createdAt).toLocaleDateString()}`;
    document.getElementById("info-nombre")!.textContent = planilla.nombre;
    document.getElementById("info-tipo")!.innerHTML = `<span class="inline-flex items-center font-medium rounded-md px-1.5 py-0.5 text-xs ring-1 ring-inset bg-info-50 text-info-700 ring-info-600/20 dark:bg-info-950 dark:text-info-400 dark:ring-info-500/30">${getTipoLabel(planilla.tipo)}</span>`;
    document.getElementById("info-activo")!.innerHTML = planilla.activo
      ? '<span class="inline-flex items-center font-medium rounded-md px-1.5 py-0.5 text-xs ring-1 ring-inset bg-success-50 text-success-700 ring-success-600/20 dark:bg-success-950 dark:text-success-400 dark:ring-success-500/30">Activo</span>'
      : '<span class="inline-flex items-center font-medium rounded-md px-1.5 py-0.5 text-xs ring-1 ring-inset bg-gray-100 text-gray-700 ring-gray-600/20 dark:bg-gray-800 dark:text-gray-300 dark:ring-gray-500/30">Inactivo</span>';
    document.getElementById("info-descripcion")!.textContent = planilla.descripcion || "Sin descripción";

    workersList = planilla.workers || [];
    document.getElementById("info-workers-count")!.textContent = String(workersList.length);
    renderWorkers(workersList);
  }

  function renderWorkers(workers: any[]) {
    const container = document.getElementById("workers-table-container")!;

    if (workers.length === 0) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center py-12 text-center">
          <svg class="size-10 text-gray-300 dark:text-gray-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zm-4 7a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <h3 class="mt-3 text-base font-semibold text-gray-900 dark:text-white">Sin trabajadores asignados</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Agrega trabajadores a esta planilla usando el botón superior.</p>
        </div>
      `;
      return;
    }

    const rows = workers.map((w: any) => `
      <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
        <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">${escapeHtml(w.nombre)}</td>
        <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">${escapeHtml(w.apellidos)}</td>
        <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">${escapeHtml(w.email)}</td>
        <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">${escapeHtml(w.cargo)}</td>
        <td class="px-4 py-3 text-sm">
          <button data-remove-worker="${w.id}" class="p-1.5 rounded-lg text-gray-400 hover:text-danger-600 hover:bg-danger-50 dark:hover:bg-danger-950 transition-colors" title="Remover trabajador">
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2M10 11v6M14 11v6"/></svg>
          </button>
        </td>
      </tr>
    `).join("");

    container.innerHTML = `
      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Nombre</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Apellidos</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cargo</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">${rows}</tbody>
        </table>
      </div>
    `;

    document.querySelectorAll("[data-remove-worker]").forEach((btn) => {
      btn.addEventListener("click", () => {
        removeWorkerId = btn.getAttribute("data-remove-worker")!;
        (window as any).__openConfirm();
      });
    });
  }

  function escapeHtml(str: string): string {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  // Add worker modal logic
  document.getElementById("btn-add-worker")?.addEventListener("click", () => {
    (window as any).__openModal();
    const searchInput = document.getElementById("worker-search-input") as HTMLInputElement;
    searchInput.value = "";
    document.getElementById("worker-search-results")!.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe para buscar trabajadores</p>';
    searchInput.focus();
  });

  document.getElementById("btn-add-worker-cancel")?.addEventListener("click", () => {
    (window as any).__closeModal();
  });

  const workerSearchInput = document.getElementById("worker-search-input") as HTMLInputElement;
  let searchTimeout: ReturnType<typeof setTimeout>;

  workerSearchInput?.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    const query = workerSearchInput.value.trim();
    if (query.length < 2) {
      document.getElementById("worker-search-results")!.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Escribe al menos 2 caracteres para buscar</p>';
      return;
    }
    searchTimeout = setTimeout(() => searchWorkers(query), 300);
  });

  async function searchWorkers(query: string) {
    const resultsContainer = document.getElementById("worker-search-results")!;
    resultsContainer.innerHTML = '<p class="text-sm text-gray-400 text-center py-4">Buscando...</p>';

    try {
      const res = await fetch(`/api/workers?search=${encodeURIComponent(query)}&limit=20`);
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message);

      const available = json.data.filter((w: any) => !workersList.some((aw: any) => aw.id === w.id));

      if (available.length === 0) {
        resultsContainer.innerHTML = '<p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">No se encontraron trabajadores disponibles</p>';
        return;
      }

      resultsContainer.innerHTML = available.map((w: any) => `
        <div class="flex items-center justify-between p-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 dark:text-white truncate">${escapeHtml(w.nombre)} ${escapeHtml(w.apellidos)}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">${escapeHtml(w.email)} - ${escapeHtml(w.cargo || "Sin cargo")}</p>
          </div>
          <button data-assign-worker="${w.id}" class="shrink-0 px-3 py-1.5 text-xs font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors">
            Asignar
          </button>
        </div>
      `).join("");

      document.querySelectorAll("[data-assign-worker]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const trabajadorId = btn.getAttribute("data-assign-worker")!;
          try {
            const res = await fetch(`/api/payrolls/${payrollId}/workers`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ trabajador_id: trabajadorId }),
            });
            const json = await res.json();
            if (!json.success) throw new Error(json.error?.message || "Error al asignar");
            showAlert("Trabajador asignado correctamente", "success");
            (window as any).__closeModal();
            loadPayroll();
          } catch (err) {
            showAlert(err instanceof Error ? err.message : "Error al asignar", "error");
          }
        });
      });
    } catch {
      resultsContainer.innerHTML = '<p class="text-sm text-danger-500 text-center py-4">Error al buscar trabajadores</p>';
    }
  }

  // Remove worker confirm
  document.addEventListener("confirm-ok", async () => {
    if (!removeWorkerId) return;
    const id = removeWorkerId;
    removeWorkerId = null;
    try {
      const res = await fetch(`/api/payrolls/${payrollId}/workers`, {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ trabajador_id: id }),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message || "Error al remover");
      showAlert("Trabajador removido correctamente", "success");
      loadPayroll();
    } catch (err) {
      showAlert(err instanceof Error ? err.message : "Error al remover", "error");
    }
  });

  // Initial load
  loadPayroll();
</script>


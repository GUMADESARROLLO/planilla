---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import DataTable from "@components/ui/DataTable.astro";
import Modal from "@components/ui/Modal.astro";
import FormField from "@components/ui/FormField.astro";
import Badge from "@components/ui/Badge.astro";
import ConfirmDialog from "@components/shared/ConfirmDialog.astro";
import { Plus, Pencil, Trash2, ToggleLeft, ToggleRight, ArrowLeft } from "@lucide/astro";
import type { Column } from "@components/ui/DataTable.astro";
import { requireAuth } from "@middleware/auth";
import { catalogService } from "@modules/catalogs/services/catalog.service";
import { db } from "@db/index";
import { unidadesNegocio, departamentos } from "@db/schemas";
import { isNull } from "drizzle-orm";

await requireAuth(Astro);

const { type } = Astro.params;
const path = Astro.url.pathname;

if (!type || !catalogService.getCatalogConfig(type)) {
  return Astro.redirect("/catalogs");
}

const config = catalogService.getCatalogConfig(type)!;

const url = Astro.url;
const page = parseInt(url.searchParams.get("page") ?? "1", 10);
const limit = parseInt(url.searchParams.get("limit") ?? "10", 10);
const search = url.searchParams.get("search") ?? undefined;

const needsUnidad = type === "departamentos" || type === "cargos";
const needsDepto = type === "cargos";

const [result, unidadesList, deptosList] = await Promise.all([
  catalogService.findAll(type, { page, limit, search }),
  needsUnidad
    ? db.select({ id: unidadesNegocio.id, nombre: unidadesNegocio.nombre }).from(unidadesNegocio).where(isNull(unidadesNegocio.deleted_at))
    : Promise.resolve([]),
  needsDepto
    ? db.select({ id: departamentos.id, nombre: departamentos.nombre, unidadNegocioId: departamentos.unidadNegocioId }).from(departamentos).where(isNull(departamentos.deleted_at))
    : Promise.resolve([]),
]);

const columns: Column[] = [
  { key: "nombre", label: "Nombre", sortable: true },
  ...(type === "departamentos"
    ? [{
        key: "unidadNegocioId",
        label: "Unidad de Negocio",
        render: (v: number) => unidadesList.find(u => u.id === v)?.nombre ?? "-",
      } as Column]
    : []),
  ...(type === "cargos"
    ? [{
        key: "unidadNegocioId",
        label: "Unidad de Negocio",
        render: (v: number) => unidadesList.find(u => u.id === v)?.nombre ?? "-",
      } as Column, {
        key: "departamentoId",
        label: "Departamento",
        render: (v: number) => deptosList.find(d => d.id === v)?.nombre ?? "-",
      } as Column]
    : []),
  ...(type === "horarios"
    ? [{
        key: "horaInicio",
        label: "Hora Entrada",
        render: (v: string) => v ?? "-",
      } as Column, {
        key: "horaFin",
        label: "Hora Salida",
        render: (v: string) => v ?? "-",
      } as Column]
    : []),
  {
    key: "descripcion",
    label: "Descripción",
    render: (v: unknown) => (v && typeof v === "string" ? v : "—"),
  },
  {
    key: "activo",
    label: "Activo",
    render: (v: boolean) => (v ? "Sí" : "No"),
  },
  {
    key: "id",
    label: "Acciones",
    render: (v: string) => v,
  },
];
---

<AppLayout title={config.displayName} currentPath={path}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <a
          href="/catalogs"
          class="flex items-center justify-center size-9 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 transition-colors"
          aria-label="Volver a catálogos"
        >
          <ArrowLeft class="size-4" />
        </a>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">{config.displayName}</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
            {result.total} {result.total === 1 ? "registro" : "registros"} en total
          </p>
        </div>
      </div>
      <Button id="btn-nuevo" type="button">
        <Plus class="size-4" slot="icon" />
        Nuevo
      </Button>
    </div>

    <!-- Data Table -->
    <DataTable
      columns={columns}
      data={result.data}
      meta={{
        page: result.page,
        totalPages: Math.ceil(result.total / result.limit),
        total: result.total,
        limit: result.limit,
      }}
      searchValue={search ?? ""}
      sortKey={url.searchParams.get("sort") ?? undefined}
      sortDir={(url.searchParams.get("dir") as "asc" | "desc") ?? undefined}
    />
  </div>
</AppLayout>

<!-- Create / Edit Modal -->
<Modal title="Nuevo registro" size="md" id="catalog-modal">
  <form id="catalog-form" slot="body" class="space-y-4">
    <input type="hidden" id="form-id" name="id" value="" />
    <FormField label="Nombre" name="nombre" required>
      <input
        id="form-nombre"
        name="nombre"
        type="text"
        required
        class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        placeholder="Nombre del registro"
      />
    </FormField>
    {type !== "horarios" && (
      <FormField label="Descripción" name="descripcion">
      <textarea
        id="form-descripcion"
        name="descripcion"
        rows={3}
        class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-none"
        placeholder="Descripción opcional"
      ></textarea>
    </FormField>
    )}
    {type === "departamentos" && (
      <FormField label="Unidad de Negocio" name="unidadNegocioId" required>
        <select
          id="form-unidad-negocio"
          name="unidadNegocioId"
          required
          class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        >
          <option value="">Seleccione unidad</option>
          {unidadesList.map((u) => (
            <option value={u.id}>{u.nombre}</option>
          ))}
        </select>
      </FormField>
    )}
    {type === "cargos" && (
      <>
        <FormField label="Unidad de Negocio" name="unidadNegocioId">
          <select
            id="form-cargo-unidad"
            name="unidadNegocioId"
            class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
          >
            <option value="">Seleccione unidad</option>
            {unidadesList.map((u) => (
              <option value={u.id}>{u.nombre}</option>
            ))}
          </select>
        </FormField>
        <FormField label="Departamento" name="departamentoId">
          <select
            id="form-cargo-depto"
            name="departamentoId"
            class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
          >
            <option value="">Seleccione departamento</option>
            {deptosList.map((d) => (
              <option value={d.id} data-unidad-id={d.unidadNegocioId}>{d.nombre}</option>
            ))}
          </select>
        </FormField>
      </>
    )}
      {type === "horarios" && (
        <>
          <FormField label="Horario" name="descripcion">
            <textarea
              id="form-descripcion"
              name="descripcion"
              rows={2}
              class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-none"
              placeholder="Descripción del horario"
            ></textarea>
          </FormField>
          <div class="grid grid-cols-2 gap-3">
            <FormField label="Hora de Entrada" name="horaInicio" required>
              <input
                id="form-hora-inicio"
                name="horaInicio"
                type="text"
                required
                class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                placeholder="07:30"
                autocomplete="off"
              />
            </FormField>
            <FormField label="Hora de Salida" name="horaFin" required>
              <input
                id="form-hora-fin"
                name="horaFin"
                type="text"
                required
                class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                placeholder="17:30"
                autocomplete="off"
              />
            </FormField>
          </div>
        </>
      )}
    <label class="flex items-center gap-3 cursor-pointer">
      <input
        id="form-activo"
        name="activo"
        type="checkbox"
        checked
        class="size-4 rounded border-gray-300 dark:border-gray-600 text-primary-600 focus:ring-primary-500 cursor-pointer"
      />
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300 select-none">Registro activo</span>
    </label>
  </form>
  <div slot="footer" class="flex items-center gap-3">
    <button
      id="modal-cancel"
      type="button"
      class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-colors"
    >
      Cancelar
    </button>
    <button
      id="modal-save"
      type="button"
      class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 transition-colors"
    >
      Guardar
    </button>
  </div>
</Modal>

<!-- Delete Confirmation -->
<ConfirmDialog
  title="Eliminar registro"
  message="¿Estás seguro de que deseas eliminar este registro? Esta acción no se puede deshacer."
  confirmText="Eliminar"
  cancelText="Cancelar"
  variant="danger"
/>

<div id="catalog-page-type" data-type={type} class="hidden"></div>
<textarea id="catalog-unidades" class="hidden" set:html={JSON.stringify(unidadesList)}></textarea>
<textarea id="catalog-deptos" class="hidden" set:html={JSON.stringify(deptosList)}></textarea>

<script>
  import Swal from "sweetalert2";
  import flatpickr from "flatpickr";
  import "flatpickr/dist/flatpickr.min.css";
  import "flatpickr/dist/themes/dark.css";
  const catalogType = document.getElementById("catalog-page-type")?.getAttribute("data-type") ?? "";
  const state = { type: catalogType, editingId: null };

  const form = document.getElementById("catalog-form") as HTMLFormElement;
  const formId = document.getElementById("form-id") as HTMLInputElement;
  const formNombre = document.getElementById("form-nombre") as HTMLInputElement;
  const formDescripcion = document.getElementById("form-descripcion") as HTMLTextAreaElement;
  const formActivo = document.getElementById("form-activo") as HTMLInputElement;
  const formUnidad = document.getElementById("form-unidad-negocio") as HTMLSelectElement | null;
  const formCargoUnidad = document.getElementById("form-cargo-unidad") as HTMLSelectElement | null;
  const formCargoDepto = document.getElementById("form-cargo-depto") as HTMLSelectElement | null;
  const formHoraInicio = document.getElementById("form-hora-inicio") as HTMLInputElement | null;
  const formHoraFin = document.getElementById("form-hora-fin") as HTMLInputElement | null;

  const btnNuevo = document.getElementById("btn-nuevo") as HTMLElement;
  const modalCancel = document.getElementById("modal-cancel") as HTMLElement;
  const modalSave = document.getElementById("modal-save") as HTMLElement;

  let deletingId: string | null = null;

  // Cascading: Unidad → Departamento for cargos
  const deptosData = (() => {
    try {
      return JSON.parse((document.getElementById("catalog-deptos") as HTMLTextAreaElement)?.value ?? "[]");
    } catch { return []; }
  })();

  function filterCargoDeptos() {
    if (!formCargoDepto || !formCargoUnidad) return;
    const unidadId = formCargoUnidad.value;
    const currentValue = formCargoDepto.value;
    formCargoDepto.innerHTML = '<option value="">Seleccione departamento</option>';
    deptosData.forEach((d: any) => {
      if (!unidadId || String(d.unidadNegocioId) === unidadId) {
        const opt = document.createElement("option");
        opt.value = d.id;
        opt.textContent = d.nombre;
        if (String(d.id) === currentValue) opt.selected = true;
        formCargoDepto.appendChild(opt);
      }
    });
  }

  if (formCargoUnidad) {
    formCargoUnidad.addEventListener("change", filterCargoDeptos);
  }

  // Flatpickr time pickers for horarios
  let fpHoraInicio: any = null;
  let fpHoraFin: any = null;
  [formHoraInicio, formHoraFin].forEach((el) => {
    if (el) {
      const fp = flatpickr(el, {
        enableTime: true,
        noCalendar: true,
        dateFormat: "H:i",
        altFormat: "h:i K",
        altInput: true,
        time_24hr: false,
        allowInput: true,
      });
      if (el === formHoraInicio) fpHoraInicio = fp;
      else fpHoraFin = fp;
    }
  });

  function resetForm() {
    formId.value = "";
    formNombre.value = "";
    formDescripcion.value = "";
    formActivo.checked = true;
    if (formUnidad) formUnidad.value = "";
    if (formCargoUnidad) formCargoUnidad.value = "";
    if (formCargoDepto) { formCargoDepto.innerHTML = '<option value="">Seleccione departamento</option>'; }
    if (formHoraInicio) { formHoraInicio.value = ""; if (fpHoraInicio) fpHoraInicio.clear(); }
    if (formHoraFin) { formHoraFin.value = ""; if (fpHoraFin) fpHoraFin.clear(); }
    state.editingId = null;
  }

  function fillForm(row: any) {
    formId.value = row.id;
    formNombre.value = row.nombre ?? "";
    formDescripcion.value = row.descripcion ?? "";
    formActivo.checked = row.activo !== false;
    if (formUnidad) formUnidad.value = row.unidadNegocioId ?? "";
    if (formCargoUnidad) formCargoUnidad.value = row.unidadNegocioId ?? "";
    if (formCargoDepto) {
      formCargoDepto.value = row.departamentoId ?? "";
      filterCargoDeptos();
    }
    if (formHoraInicio && row.horaInicio) { formHoraInicio.value = row.horaInicio; if (fpHoraInicio) fpHoraInicio.setDate(row.horaInicio); }
    else if (formHoraInicio) { formHoraInicio.value = ""; if (fpHoraInicio) fpHoraInicio.clear(); }
    if (formHoraFin && row.horaFin) { formHoraFin.value = row.horaFin; if (fpHoraFin) fpHoraFin.setDate(row.horaFin); }
    else if (formHoraFin) { formHoraFin.value = ""; if (fpHoraFin) fpHoraFin.clear(); }
    state.editingId = row.id;
  }

  function openModal(title: string) {
    const titleEl = document.getElementById("modal-title");
    if (titleEl) titleEl.textContent = title;
    (window as any).__openModal?.();
  }

  function closeModal() {
    (window as any).__closeModal?.();
  }

  btnNuevo.addEventListener("click", () => {
    resetForm();
    openModal("Nuevo registro");
  });

  modalCancel.addEventListener("click", closeModal);

  async function handleSave() {
    const nombre = formNombre.value.trim();
    if (!nombre) {
      formNombre.focus();
      return;
    }

    const body: Record<string, any> = {
      nombre,
      descripcion: formDescripcion.value.trim() || null,
      activo: formActivo.checked,
    };
    if (formUnidad) body.unidadNegocioId = formUnidad.value ? Number(formUnidad.value) : null;
    if (formCargoUnidad) body.unidadNegocioId = formCargoUnidad.value ? Number(formCargoUnidad.value) : null;
    if (formCargoDepto) body.departamentoId = formCargoDepto.value ? Number(formCargoDepto.value) : null;
    if (formHoraInicio) body.horaInicio = formHoraInicio.value || null;
    if (formHoraFin) body.horaFin = formHoraFin.value || null;

    const isEditing = state.editingId !== null;
    const url = isEditing
      ? `/api/catalogs/${state.type}/${state.editingId}`
      : `/api/catalogs/${state.type}`;
    const method = isEditing ? "PUT" : "POST";

    Swal.fire({
      title: isEditing ? "Actualizando..." : "Guardando...",
      text: "Espere mientras se procesa la solicitud",
      allowOutsideClick: false,
      didOpen: () => Swal.showLoading(),
    });

    try {
      const res = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error?.message || "Error al guardar");
      }

      closeModal();
      await Swal.fire({
        icon: "success",
        title: isEditing ? "¡Actualizado!" : "¡Creado!",
        text: isEditing ? "Registro actualizado correctamente" : "Registro creado correctamente",
        timer: 1500,
        showConfirmButton: false,
      });
      window.location.reload();
    } catch (err: any) {
      Swal.fire("Error", err.message, "error");
    }
  }

  modalSave.addEventListener("click", handleSave);

  form.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !(e.target instanceof HTMLTextAreaElement)) {
      e.preventDefault();
      handleSave();
    }
  });

  document.addEventListener("confirm-ok", async () => {
    if (!deletingId) return;
    try {
      const res = await fetch(`/api/catalogs/${state.type}/${deletingId}`, {
        method: "DELETE",
      });
      if (!res.ok) {
        const err = await res.json();
        alert(err.error?.message || "Error al eliminar");
        return;
      }
      window.location.reload();
    } catch {
      alert("Error de conexión al eliminar");
    }
  });

  async function toggleActive(row: any) {
    try {
      const res = await fetch(`/api/catalogs/${state.type}/${row.id}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ activo: !row.activo }),
      });
      if (!res.ok) {
        const err = await res.json();
        alert(err.error?.message || "Error al cambiar estado");
        return;
      }
      window.location.reload();
    } catch {
      alert("Error de conexión");
    }
  }

  function confirmDelete(id: string) {
    deletingId = id;
    (window as any).__openConfirm?.();
  }

  function enhanceTable() {
    const rows = document.querySelectorAll("table tbody tr");
    if (!rows.length) return;

    const headerRow = document.querySelector("table thead tr");
    if (headerRow) {
      const lastTh = headerRow.lastElementChild as HTMLElement;
      if (lastTh) lastTh.style.width = "180px";
    }

    rows.forEach((row) => {
      const cells = row.querySelectorAll("td");
      const lastCell = cells[cells.length - 1];
      if (!lastCell) return;

      const id = lastCell.textContent?.trim() ?? "";

      const rowData = Array.from(cells)
        .slice(0, -1)
        .map((c) => c.textContent?.trim() ?? "");

      const nombre = rowData[0] ?? "";

      const rowObj = { id, nombre, activo: rowData[rowData.length - 1] === "Sí" };

      lastCell.innerHTML = `
        <div class="flex items-center gap-1">
          <button type="button" data-edit="${id}"
            class="p-1.5 rounded-md text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-900/30 transition-colors"
            title="Editar">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
          </button>
          <button type="button" data-toggle="${id}"
            class="p-1.5 rounded-md text-gray-400 hover:text-warning-600 hover:bg-warning-50 dark:hover:text-warning-400 dark:hover:bg-warning-900/30 transition-colors"
            title="${rowObj.activo ? "Desactivar" : "Activar"}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><rect x="1" y="5" width="22" height="14" rx="7" ry="7"/><circle cx="8" cy="12" r="3"/></svg>
          </button>
          <button type="button" data-delete="${id}"
            class="p-1.5 rounded-md text-gray-400 hover:text-danger-600 hover:bg-danger-50 dark:hover:text-danger-400 dark:hover:bg-danger-900/30 transition-colors"
            title="Eliminar">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
        </div>
      `;

      lastCell.querySelector("[data-edit]")?.addEventListener("click", async () => {
        try {
          const res = await fetch(`/api/catalogs/${state.type}/${id}`);
          if (!res.ok) return;
          const json = await res.json();
          if (json.success && json.data) {
            fillForm(json.data);
            openModal("Editar registro");
          }
        } catch {
          alert("Error al cargar datos");
        }
      });

      lastCell.querySelector("[data-toggle]")?.addEventListener("click", () => {
        toggleActive(rowObj);
      });

      lastCell.querySelector("[data-delete]")?.addEventListener("click", () => {
        confirmDelete(id);
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", enhanceTable);
  } else {
    enhanceTable();
  }

  // Search
  document.addEventListener("datatable-search", ((e: CustomEvent) => {
    const value = e.detail.value;
    const url = new URL(window.location.href);
    if (value) url.searchParams.set("search", value);
    else url.searchParams.delete("search");
    url.searchParams.set("page", "1");
    window.location.href = url.toString();
  }) as EventListener);

  // Pagination
  document.addEventListener("datatable-page", ((e: CustomEvent) => {
    let page: number;
    const currentPage = parseInt(new URL(window.location.href).searchParams.get("page") ?? "1", 10);
    const totalPages = parseInt(
      document.querySelector('[data-total-pages]')?.getAttribute("data-total-pages") ?? "1",
      10,
    );

    if (e.detail.page === "prev") page = Math.max(1, currentPage - 1);
    else if (e.detail.page === "next") page = Math.min(totalPages, currentPage + 1);
    else page = parseInt(e.detail.page, 10);

    const url = new URL(window.location.href);
    if (page > 1) url.searchParams.set("page", String(page));
    else url.searchParams.delete("page");
    window.location.href = url.toString();
  }) as EventListener);

  // Sort
  document.addEventListener("datatable-sort", ((e: CustomEvent) => {
    const key = e.detail.key;
    const url = new URL(window.location.href);
    const currentDir = url.searchParams.get("dir");
    const newDir = currentDir === "asc" ? "desc" : "asc";
    url.searchParams.set("sort", key);
    url.searchParams.set("dir", newDir);
    url.searchParams.set("page", "1");
    window.location.href = url.toString();
  }) as EventListener);
</script>


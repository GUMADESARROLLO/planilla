---
import AppLayout from "@components/layout/AppLayout.astro";
import Card from "@components/ui/Card.astro";
import Button from "@components/ui/Button.astro";
import Badge from "@components/ui/Badge.astro";
import { dashboardService } from "@modules/dashboard/services/dashboard.service";
import { requireAuth } from "@middleware/auth";
import {
  Users,
  UserCheck,
  FileSpreadsheet,
  Clock,
  Plus,
  ArrowRight,
  BarChart3,
  Activity,
  CheckCircle,
  XCircle,
} from "@lucide/astro";

await requireAuth(Astro);

const stats = await dashboardService.getStats();
const recentWorkers = await dashboardService.getRecentWorkers(5);
const recentPermits = await dashboardService.getRecentPendingPermits(5);
const path = Astro.url.pathname;

const now = new Date();
const dateStr = now.toLocaleDateString("es-ES", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---

<AppLayout title="Dashboard" currentPath={path}>
  <div class="space-y-6">
    <!-- Welcome Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
          Panel de Control
        </h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
          {capitalize(dateStr)}
        </p>
      </div>
      <div class="flex items-center gap-2">
        <Button href="/workers" size="sm" variant="outline">
          <Plus class="size-3.5" slot="icon" />
          Nuevo Trabajador
        </Button>
        <Button href="/payrolls" size="sm" variant="outline">
          <Plus class="size-3.5" slot="icon" />
          Nueva Planilla
        </Button>
        <Button href="/permits" size="sm" variant="outline">
          <Plus class="size-3.5" slot="icon" />
          Nueva Esquela
        </Button>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Total Workers -->
      <Card padding={false}>
        <div class="p-5" slot="body">
          <div class="flex items-center justify-between">
            <div class="flex items-center justify-center size-11 rounded-xl bg-primary-100 dark:bg-primary-900/50">
              <Users class="size-5 text-primary-600 dark:text-primary-400" />
            </div>
            <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 px-2 py-0.5 rounded-full">
              <Activity class="size-3" />
              Total
            </span>
          </div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white mt-4">
            {stats.totalWorkers}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Total Trabajadores
          </p>
        </div>
      </Card>

      <!-- Active Workers -->
      <Card padding={false}>
        <div class="p-5" slot="body">
          <div class="flex items-center justify-between">
            <div class="flex items-center justify-center size-11 rounded-xl bg-success-100 dark:bg-success-900/50">
              <UserCheck class="size-5 text-success-600 dark:text-success-400" />
            </div>
            <Badge variant="success" size="sm">
              {stats.activeWorkers > 0 ? ((stats.activeWorkers / (stats.totalWorkers || 1)) * 100).toFixed(0) : 0}%
            </Badge>
          </div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white mt-4">
            {stats.activeWorkers}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Trabajadores Activos
          </p>
        </div>
      </Card>

      <!-- Payrolls -->
      <Card padding={false}>
        <div class="p-5" slot="body">
          <div class="flex items-center justify-between">
            <div class="flex items-center justify-center size-11 rounded-xl bg-warning-100 dark:bg-warning-900/50">
              <FileSpreadsheet class="size-5 text-warning-600 dark:text-warning-400" />
            </div>
          </div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white mt-4">
            {stats.totalPayrolls}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Planillas Registradas
          </p>
        </div>
      </Card>

      <!-- Pending Permits -->
      <Card padding={false}>
        <div class="p-5" slot="body">
          <div class="flex items-center justify-between">
            <div class="flex items-center justify-center size-11 rounded-xl bg-danger-100 dark:bg-danger-900/50">
              <Clock class="size-5 text-danger-600 dark:text-danger-400" />
            </div>
          </div>
          <p class="text-3xl font-bold text-gray-900 dark:text-white mt-4">
            {stats.pendingPermits}
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Permisos Pendientes
          </p>
        </div>
      </Card>
    </div>

    <!-- Charts Row / Secondary Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Vacaciones acumuladas por departamento -->
      <Card title="Vacaciones por Departamento" subtitle="Saldo acumulado por unidad de negocio">
        <div slot="body" class="space-y-4">
          {stats.vacacionesByUnidad.length > 0 ? (
            (() => {
              let currentUnidad = "";
              const rows: any[] = [];
              for (const item of stats.vacacionesByUnidad) {
                if (item.unidadNegocio !== currentUnidad) {
                  currentUnidad = item.unidadNegocio;
                  rows.push({ type: "header", label: currentUnidad });
                }
                rows.push({ type: "item", ...item });
              }
              return rows.map((row: any) =>
                row.type === "header" ? (
                  <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider mt-3 first:mt-0">
                    {row.label}
                  </p>
                ) : (
                  <div class="flex items-center gap-3">
                    <span class="text-sm text-gray-700 dark:text-gray-300 w-40 truncate shrink-0">
                      {row.departamento}
                    </span>
                    <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
                      <div
                        class="h-full bg-warning-500 rounded-full transition-all"
                        style={`width: ${Math.min((row.totalVacaciones / 30) * 100, 100)}%`}
                      ></div>
                    </div>
                    <span class="text-sm font-medium text-gray-900 dark:text-white w-16 text-right shrink-0">
                      {row.totalVacaciones.toFixed(1)}
                    </span>
                    <span class="text-xs text-gray-400 dark:text-gray-500 w-12 text-right shrink-0">
                      {row.workerCount} trab.
                    </span>
                  </div>
                )
              );
            })()
          ) : (
            <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">
              No hay datos disponibles
            </p>
          )}
        </div>
      </Card>
    </div>

    <!-- Recent Tables Row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Recent Workers -->
      <Card title="Últimos Trabajadores" subtitle="Registros recientes">
        <a slot="action" href="/workers" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 transition-colors">
          Ver todos
          <ArrowRight class="size-3.5" />
        </a>
        <div slot="body" class="-mx-6 -mt-2">
          <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-800">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Nombre</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Estado</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
              {recentWorkers.length > 0 ? (
                recentWorkers.map((w) => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                    <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap">
                      {w.nombre} {w.apellidos}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">{w.email}</td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      {w.activo
                        ? <Badge variant="success">Activo</Badge>
                        : <Badge variant="danger">Inactivo</Badge>
                      }
                    </td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td colspan={3} class="px-4 py-8 text-center text-sm text-gray-400 dark:text-gray-500">
                    No hay trabajadores registrados
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </Card>

      <!-- Recent Permits -->
      <Card title="Permisos Pendientes" subtitle="Últimas solicitudes">
        <a slot="action" href="/permits" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 transition-colors">
          Ver todos
          <ArrowRight class="size-3.5" />
        </a>
        <div slot="body" class="-mx-6 -mt-2">
          <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-800">
            <thead class="bg-gray-50 dark:bg-gray-900">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trabajador</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Días</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Estado</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
              {recentPermits.length > 0 ? (
                recentPermits.map((p) => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                      {p.trabajadorId}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                      {p.cantidadDias} {p.cantidadDias === 1 ? "día" : "días"}
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <Badge variant="warning">Pendiente</Badge>
                    </td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td colspan={3} class="px-4 py-8 text-center text-sm text-gray-400 dark:text-gray-500">
                    No hay permisos pendientes
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </Card>
    </div>
  </div>
</AppLayout>

---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import { ArrowLeft, Save } from "@lucide/astro";
import { db } from "@db/index";
import {
  tiposContrato,
  cargos,
  generos,
  nacionalidades,
  tallasCamisa,
  tallasPantalon,
  trabajadores,
  horarios,
  deptosNi,
  municipios,
  planillas,
  tiposMoneda,
  formasPago,
} from "@db/schemas";
import { trabajadoresPlanillas } from "@db/schemas/workers_planillas";
import { eq, isNull } from "drizzle-orm";
import WorkerForm from "../_form.astro";

const currentPath = "/workers";
const idParam = Astro.params.id;
if (!idParam) return Astro.redirect("/workers");
const id = Number(idParam);

const [workerRow, tiposContratoList, cargosList, generosList, nacionalidadesList, tallasCamisaList, tallasPantalonList, horariosList, deptosNiList, municipiosList, planillasList, workerPlanillas, tiposMonedaList, formasPagoList] =
  await Promise.all([
    db.select({
      id: trabajadores.id,
      nombre: trabajadores.nombre,
      apellidos: trabajadores.apellidos,
      email: trabajadores.email,
      telefono: trabajadores.telefono,
      activo: trabajadores.activo,
      foto: trabajadores.foto,
      fechaEntrada: trabajadores.fechaEntrada,
      fechaSalida: trabajadores.fechaSalida,
      nacionalidadId: trabajadores.nacionalidadId,
      numeroInss: trabajadores.numeroInss,
      cedulaIdentidad: trabajadores.cedulaIdentidad,
      saldoVacaciones: trabajadores.saldoVacaciones,
      tallaCamisaId: trabajadores.tallaCamisaId,
      tallaPantalonId: trabajadores.tallaPantalonId,
      horarioId: trabajadores.horarioId,
      direccion: trabajadores.direccion,
      tipoContratoId: trabajadores.tipoContratoId,
      cargoId: trabajadores.cargoId,
      generoId: trabajadores.generoId,
      salarioBase: trabajadores.salarioBase,
      municipioId: trabajadores.municipioId,
      tipoMonedaId: trabajadores.tipoMonedaId,
      formaPagoId: trabajadores.formaPagoId,
      cuentaNomina: trabajadores.cuentaNomina,
      sueldoEmbargable: trabajadores.sueldoEmbargable,
      sueldoEmbargablePorcentaje: trabajadores.sueldoEmbargablePorcentaje,
      depreciacionVehicular: trabajadores.depreciacionVehicular,
      depreciacionMontoAplicar: trabajadores.depreciacionMontoAplicar,
      depreciacionMontoFijo: trabajadores.depreciacionMontoFijo,
      depreciacionDolar: trabajadores.depreciacionDolar,
      descripcionVehiculo: trabajadores.descripcionVehiculo,
      created_at: trabajadores.created_at,
      updated_at: trabajadores.updated_at,
      deleted_at: trabajadores.deleted_at,
    })
      .from(trabajadores)
      .where(eq(trabajadores.id, id))
      .limit(1)
      .then((r: any[]) => r[0]),
    db.select().from(tiposContrato).where(isNull(tiposContrato.deleted_at)),
    db.select().from(cargos).where(isNull(cargos.deleted_at)),
    db.select().from(generos).where(isNull(generos.deleted_at)),
    db.select().from(nacionalidades).where(isNull(nacionalidades.deleted_at)),
    db.select().from(tallasCamisa).where(isNull(tallasCamisa.deleted_at)),
    db.select().from(tallasPantalon).where(isNull(tallasPantalon.deleted_at)),
    db.select().from(horarios).where(isNull(horarios.deleted_at)),
    db.select().from(deptosNi),
    db.select().from(municipios),
    db.select().from(planillas).where(isNull(planillas.deleted_at)),
    db
      .select({ planillaId: trabajadoresPlanillas.planillaId })
      .from(trabajadoresPlanillas)
      .where(eq(trabajadoresPlanillas.trabajadorId, id)),
    db.select().from(tiposMoneda).where(isNull(tiposMoneda.deleted_at)),
    db.select().from(formasPago).where(isNull(formasPago.deleted_at)),
  ]);

const workerPlanillaIds = new Set(workerPlanillas.map((wp: any) => wp.planillaId));

if (!workerRow) return Astro.redirect("/workers");
const fmt = (d: Date | string | null) => d ? new Date(d).toLocaleDateString("en-CA") : "";
const deptoNiId = municipiosList.find((m: any) => m.id === workerRow.municipioId)?.deptoNiId ?? null;
const worker = { ...workerRow, deptoNiId, fechaEntrada: fmt(workerRow.fechaEntrada), fechaSalida: fmt(workerRow.fechaSalida) };
---

<AppLayout title={`Editar: ${worker.nombre} ${worker.apellidos}`} {currentPath}>
  <div class="space-y-6">
    <!-- Header with actions -->
    <div class="flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <a
          href="/workers"
          class="p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 transition-colors"
          aria-label="Volver"
        >
          <ArrowLeft class="size-5" />
        </a>
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Trabajador</h1>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
            Actualizando: {worker.nombre} {worker.apellidos}
          </p>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a
          href="/workers"
          class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
        >
          Cancelar
        </a>
        <Button id="btn-submit-worker" variant="primary">
          <Save slot="icon" class="size-4" />
          Actualizar
        </Button>
      </div>
    </div>

    <!-- Form -->
    <form id="worker-form-page" novalidate>
      <WorkerForm
        tiposContrato={tiposContratoList}
        cargos={cargosList}
        generos={generosList}
        nacionalidades={nacionalidadesList}
        tallasCamisa={tallasCamisaList}
        tallasPantalon={tallasPantalonList}
        horarios={horariosList}
        deptosNi={deptosNiList}
        municipios={municipiosList}
        tiposMoneda={tiposMonedaList}
        formasPago={formasPagoList}
        worker={worker}
        mode="edit"
      />
    </form>

    <!-- Planillas Section -->
    <div class="ep-section">
      <div class="ep-section-header">
        <svg class="ep-section-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        <span class="ep-section-title">Planillas</span>
      </div>
      <div class="ep-section-body ep-planillas-grid">
        {planillasList.length === 0 ? (
          <p class="text-sm text-gray-500 dark:text-gray-400">No hay planillas disponibles</p>
        ) : (
          planillasList.map((p: any) => {
            const checked = workerPlanillaIds.has(p.id);
            return (
              <label class="ep-planilla-item" data-planilla-id={p.id}>
                <input
                  type="checkbox"
                  class="ep-planilla-checkbox"
                  data-planilla-id={p.id}
                  checked={checked}
                />
                <div class="ep-planilla-info">
                  <span class="ep-planilla-name">{p.nombre}</span>
                  <span class="ep-planilla-tipo">{p.tipo}</span>
                </div>
              </label>
            );
          })
        )}
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import Swal from "sweetalert2";
  import $ from "jquery";
  import "inputmask/dist/jquery.inputmask.js";

  ($ as any)(document).ready(() => {
    ($ as any)("#field-telefono").inputmask("9999-9999", { placeholder: "0000-0000" });
    ($ as any)("#field-cedulaIdentidad").inputmask("999-999999-9999A", { placeholder: "000-000000-0000A" });
  });

  document.getElementById("btn-submit-worker")?.addEventListener("click", async () => {
    const form = document.getElementById("worker-form-page") as HTMLFormElement;
    const btn = document.getElementById("btn-submit-worker") as HTMLButtonElement;
    btn.disabled = true;

    const data: Record<string, any> = {};
    const inputs = form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
      "input, select, textarea"
    );
    for (const el of inputs) {
      if (el.type === "checkbox") {
        data[el.name] = el.checked;
      } else if (el.type === "file") {
        const file = (el as HTMLInputElement).files?.[0];
        if (file) {
          if (file.size > 2 * 1024 * 1024) {
            Swal.fire("Error", "La imagen no debe exceder 2MB", "error");
            btn.disabled = false;
            return;
          }
          data[el.name] = await new Promise<string>((resolve) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result as string);
            reader.readAsDataURL(file);
          });
        }
      } else if (el.name && !el.name.startsWith("_")) {
        data[el.name] = el.value;
      }
    }

    const numFields = ["nacionalidadId","tallaCamisaId","tallaPantalonId","tipoContratoId","cargoId","generoId","horarioId","saldoVacaciones","municipioId","deptoNiId","tipoMonedaId","formaPagoId","sueldoEmbargablePorcentaje"];
    for (const f of numFields) {
      if (data[f] !== undefined) {
        if (data[f] === "") {
          delete data[f];
        } else {
          data[f] = Number(data[f]);
        }
      }
    }
    if (data.fechaSalida === "") data.fechaSalida = null;

    const workerId = form.querySelector<HTMLInputElement>("input[name='id']")?.value;
    if (!workerId) return;

    Swal.fire({
      title: "Actualizando...",
      text: "Espere mientras se actualiza el trabajador",
      allowOutsideClick: false,
      didOpen: () => Swal.showLoading(),
    });

    try {
      const res = await fetch(`/api/workers/${workerId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message ?? "Error al actualizar");
      await Swal.fire({
        icon: "success",
        title: "¡Actualizado!",
        text: "Trabajador actualizado correctamente",
        timer: 1500,
        showConfirmButton: false,
      });
    } catch (err: any) {
      Swal.fire("Error", err.message, "error");
    } finally {
      btn.disabled = false;
    }
  });

  // Planilla toggle
  document.querySelectorAll(".ep-planilla-checkbox").forEach((cb) => {
    cb.addEventListener("change", async (e) => {
      const input = e.currentTarget as HTMLInputElement;
      const planillaId = Number(input.getAttribute("data-planilla-id"));
      const label = input.closest(".ep-planilla-item") as HTMLElement;
      const workerIdEl = document.querySelector<HTMLInputElement>("input[name='id']");
      if (!workerIdEl || !planillaId) return;
      const wid = Number(workerIdEl.value);

      label.style.opacity = "0.5";
      input.disabled = true;

      try {
        const res = await fetch(`/api/workers/${wid}/planillas`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ planillaId }),
        });
        const json = await res.json();
        if (!json.success) {
          input.checked = !input.checked;
          Swal.fire("Error", json.error?.message ?? "Error al actualizar planilla", "error");
        }
      } catch {
        input.checked = !input.checked;
        Swal.fire("Error", "Error de conexión", "error");
      } finally {
        label.style.opacity = "1";
        input.disabled = false;
      }
    });
  });
</script>

<style>
  .ep-section {
    background: var(--bg-card, #181e2c);
    border: 1px solid var(--border, #262f45);
    border-radius: 14px;
    padding: 20px;
  }
  .ep-section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .ep-section-icon {
    width: 14px;
    height: 14px;
    color: var(--text-secondary, #8b9abf);
  }
  .ep-section-title {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-secondary, #8b9abf);
    text-transform: uppercase;
    letter-spacing: .07em;
  }
  .ep-section-body {
    padding: 0;
  }
  .ep-planillas-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ep-planilla-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--bg-input, #1c2335);
    border: 1px solid var(--border-light, #2d3855);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color .2s, background .2s;
    min-width: 160px;
    user-select: none;
  }
  .ep-planilla-item:hover {
    border-color: var(--border-focus, #3b6fd4);
    background: var(--bg-input-hover, #1f2840);
  }
  .ep-planilla-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--accent, #3b6fd4);
    cursor: pointer;
  }
  .ep-planilla-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ep-planilla-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary, #e8edf7);
    line-height: 1.2;
  }
  .ep-planilla-tipo {
    font-size: 11px;
    color: var(--text-muted, #4d5c7d);
    text-transform: capitalize;
  }
</style>

---
import AppLayout from "@components/layout/AppLayout.astro";
import Button from "@components/ui/Button.astro";
import Card from "@components/ui/Card.astro";
import SearchInput from "@components/shared/SearchInput.astro";
import Pagination from "@components/shared/Pagination.astro";
import ConfirmDialog from "@components/shared/ConfirmDialog.astro";
import Badge from "@components/ui/Badge.astro";
import { db } from "@db/index";
import {
  tiposContrato,
  cargos,
  generos,
  nacionalidades,
  tallasCamisa,
  tallasPantalon,
  trabajadores,
} from "@db/schemas";
import { eq, like, and, isNull, or, sql, desc } from "drizzle-orm";
import { Pencil, Trash2, Plus, Eye } from "@lucide/astro";


const currentPath = Astro.url.pathname;
const url = Astro.url;

const page = Number(url.searchParams.get("page")) || 1;
const limit = Number(url.searchParams.get("limit")) || 10;
const search = url.searchParams.get("search") ?? "";
const activoFilter = url.searchParams.get("activo") ?? "";
const tipoContratoFilter = url.searchParams.get("tipo_contrato_id");
const cargoFilter = url.searchParams.get("cargo_id");

const conditions = [isNull(trabajadores.deleted_at)];

if (search) {
  const term = `%${search}%`;
  conditions.push(
    or(
      like(trabajadores.nombre, term),
      like(trabajadores.apellidos, term),
      like(trabajadores.email, term),
      like(trabajadores.cedulaIdentidad, term),
      like(trabajadores.numeroInss, term),
    ),
  );
}

if (activoFilter === "true") conditions.push(eq(trabajadores.activo, true));
if (activoFilter === "false") conditions.push(eq(trabajadores.activo, false));
if (tipoContratoFilter) conditions.push(eq(trabajadores.tipoContratoId, Number(tipoContratoFilter)));
if (cargoFilter) conditions.push(eq(trabajadores.cargoId, Number(cargoFilter)));

const where = and(...conditions);

const [workers, countResult, tiposContratoList, cargosList, generosList, nacionalidadesList, tallasCamisaList, tallasPantalonList] =
  await Promise.all([
    db.select({
      id: trabajadores.id,
      nombre: trabajadores.nombre,
      apellidos: trabajadores.apellidos,
      email: trabajadores.email,
      telefono: trabajadores.telefono,
      activo: trabajadores.activo,
      created_at: trabajadores.created_at,
      nombreCargo: cargos.nombre,
      nombreTipoContrato: tiposContrato.nombre,
    })
      .from(trabajadores)
      .leftJoin(cargos, eq(trabajadores.cargoId, cargos.id))
      .leftJoin(tiposContrato, eq(trabajadores.tipoContratoId, tiposContrato.id))
      .where(where)
      .orderBy(desc(trabajadores.created_at))
      .limit(limit)
      .offset((page - 1) * limit),
    db.select({ count: sql<number>`count(*)` }).from(trabajadores).where(where),
    db.select().from(tiposContrato).where(isNull(tiposContrato.deleted_at)),
    db.select().from(cargos).where(isNull(cargos.deleted_at)),
    db.select().from(generos).where(isNull(generos.deleted_at)),
    db.select().from(nacionalidades).where(isNull(nacionalidades.deleted_at)),
    db.select().from(tallasCamisa).where(isNull(tallasCamisa.deleted_at)),
    db.select().from(tallasPantalon).where(isNull(tallasPantalon.deleted_at)),
  ]);

const total = Number(countResult[0]?.count ?? 0);
const totalPages = Math.ceil(total / limit);
---

<AppLayout title="Trabajadores" {currentPath}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Trabajadores</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
          Gestión de trabajadores del sistema
        </p>
      </div>
      <a
        href="/workers/new"
        class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-900 select-none px-4 py-2 text-sm gap-2 bg-primary-600 text-white hover:bg-primary-700 focus:ring-primary-500 shadow-sm shadow-primary-200 dark:shadow-primary-950"
      >
        <Plus class="size-4" />
        Nuevo Trabajador
      </a>
    </div>

    <!-- Filters -->
    <Card padding={false}>
      <div class="p-4 border-b border-gray-200 dark:border-gray-800">
        <form id="filter-form" method="GET" class="flex items-center gap-3">
          <div class="flex-1 max-w-xs">
            <SearchInput value={search} placeholder="Buscar trabajadores..." name="search" />
          </div>
          <div class="flex items-center gap-2 ml-auto">
            <select
              id="filter-tipo-contrato"
              name="tipo_contrato_id"
              class="px-3 py-2 text-sm border rounded-lg bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">Todos los contratos</option>
              {tiposContratoList.map((tc) => (
                <option value={tc.id} selected={tipoContratoFilter === String(tc.id)}>{tc.nombre}</option>
              ))}
            </select>
            <select
              id="filter-cargo"
              name="cargo_id"
              class="px-3 py-2 text-sm border rounded-lg bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">Todos los cargos</option>
              {cargosList.map((c) => (
                <option value={c.id} selected={cargoFilter === String(c.id)}>{c.nombre}</option>
              ))}
            </select>
            <select
              id="filter-activo"
              name="activo"
              class="px-3 py-2 text-sm border rounded-lg bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">Todos</option>
              <option value="true" selected={activoFilter === "true"}>Activos</option>
              <option value="false" selected={activoFilter === "false"}>Inactivos</option>
            </select>
            <Button type="submit" variant="secondary" size="md">Filtrar</Button>
            {search || activoFilter || tipoContratoFilter || cargoFilter ? (
              <a href="/workers" class="px-3 py-2 text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">Limpiar</a>
            ) : null}
          </div>
        </form>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Nombre</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Apellidos</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Cargo</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Tipo Contrato</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Teléfono</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Activo</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {workers.length === 0 ? (
              <tr>
                <td colspan="8" class="px-4 py-12 text-center text-sm text-gray-400">
                  No se encontraron trabajadores
                </td>
              </tr>
            ) : (
              workers.map((worker) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                  <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">
                    <a href={`/workers/${worker.id}`} class="hover:text-primary-600 dark:hover:text-primary-400">
                      {worker.nombre}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">{worker.apellidos}</td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">{worker.email}</td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">{worker.nombreCargo}</td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">{worker.nombreTipoContrato}</td>
                  <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300">{worker.telefono}</td>
                  <td class="px-4 py-3">
                    {worker.activo
                      ? <Badge variant="success">Activo</Badge>
                      : <Badge variant="danger">Inactivo</Badge>
                    }
                  </td>
                  <td class="px-4 py-3 text-right">
                    <div class="flex items-center justify-end gap-1">
                      <a
                        href={`/workers/${worker.id}`}
                        class="p-1.5 rounded-lg text-gray-400 hover:text-primary-600 hover:bg-primary-50 dark:hover:text-primary-400 dark:hover:bg-primary-950/50 transition-colors"
                        aria-label="Ver trabajador"
                      >
                        <Eye class="size-4" />
                      </a>
                      <a
                        href={`/workers/edit/${worker.id}`}
                        class="p-1.5 rounded-lg text-gray-400 hover:text-warning-600 hover:bg-warning-50 dark:hover:text-warning-400 dark:hover:bg-warning-950/50 transition-colors"
                        aria-label="Editar trabajador"
                      >
                        <Pencil class="size-4" />
                      </a>
                      <button
                        data-delete-id={worker.id}
                        data-delete-name={`${worker.nombre} ${worker.apellidos}`}
                        class="btn-delete p-1.5 rounded-lg text-gray-400 hover:text-danger-600 hover:bg-danger-50 dark:hover:text-danger-400 dark:hover:bg-danger-950/50 transition-colors"
                        aria-label="Eliminar trabajador"
                        type="button"
                      >
                        <Trash2 class="size-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="p-4 border-t border-gray-200 dark:border-gray-800">
          <Pagination {page} {totalPages} {total} {limit} baseUrl="/workers" />
        </div>
      )}
    </Card>
  </div>

  <!-- Delete Confirm Dialog -->
  <ConfirmDialog
    id="confirm-delete"
    title="Eliminar Trabajador"
    message="¿Estás seguro de que deseas eliminar este trabajador? Esta acción es reversible."
    confirmText="Eliminar"
    cancelText="Cancelar"
    variant="danger"
  />
</AppLayout>

<script>
  let deleteTargetId: string | null = null;

  // ---- Eliminar ----
  document.querySelectorAll(".btn-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      deleteTargetId = btn.getAttribute("data-delete-id");
      const name = btn.getAttribute("data-delete-name") ?? "este trabajador";
      const msgEl = document.querySelector("#confirm-delete #confirm-message");
      if (msgEl) msgEl.textContent = `¿Estás seguro de eliminar a "${name}"? Esta acción es reversible.`;
      (window as any).__openConfirm?.();
    });
  });

  document.addEventListener("confirm-ok", async () => {
    if (!deleteTargetId) return;
    try {
      const res = await fetch(`/api/workers/${deleteTargetId}`, { method: "DELETE" });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message ?? "Error del servidor");
      window.location.reload();
    } catch (err: any) {
      alert(err.message);
    }
    deleteTargetId = null;
  });

  document.addEventListener("confirm-cancel", () => {
    deleteTargetId = null;
  });
</script>

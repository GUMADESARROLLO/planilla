---
import AppLayout from "@components/layout/AppLayout.astro";
import Modal from "@components/ui/Modal.astro";
import { Save, Plus, Minus, DollarSign, Info, Clock } from "@lucide/astro";
import { db } from "@db/index";
import { trabajadores, cargos, tiposContrato } from "@db/schemas";
import { eq } from "drizzle-orm";

const idParam = Astro.params.id;
if (!idParam) return Astro.redirect("/workers");
const id = Number(idParam);

const worker = await db
  .select({
    id: trabajadores.id,
    nombre: trabajadores.nombre,
    apellidos: trabajadores.apellidos,
    cedulaIdentidad: trabajadores.cedulaIdentidad,
    cargo: cargos.nombre,
    tipoContrato: tiposContrato.nombre,
    salarioBase: trabajadores.salarioBase,
  })
  .from(trabajadores)
  .leftJoin(cargos, eq(trabajadores.cargoId, cargos.id))
  .leftJoin(tiposContrato, eq(trabajadores.tipoContratoId, tiposContrato.id))
  .where(eq(trabajadores.id, id))
  .limit(1)
  .then((r: any[]) => r[0]);

if (!worker) return Astro.redirect("/workers");

const currentPath = "/workers";
const title = `Ingresos y Deducciones - ${worker.nombre} ${worker.apellidos}`;
const salBase = Number(worker.salarioBase ?? 0).toLocaleString("es-NI", { minimumFractionDigits: 2 });
const workerName = `${worker.nombre} ${worker.apellidos}`;

// Generate last 6 month labels: May-19, Apr-19, ...
const monthLabels: string[] = [];
const now = new Date();
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const month = d.toLocaleDateString("en-US", { month: "short" });
  const year = String(d.getFullYear()).slice(-2);
  monthLabels.push(`${month}-${year}`);
}
const salBaseNum = Number(worker.salarioBase ?? 0);
---

<AppLayout {title} {currentPath}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-end gap-4">
      <div>
        <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">Payroll &gt; Processing</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">Employee Payroll Detail</h1>
      </div>
      <div class="flex gap-2">
        <button id="btn-historial" type="button" class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
          <Clock class="size-3.5" />
          Historial
        </button>
        <a href={`/workers/${id}`} class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
          Cancelar
        </a>
        <button class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg shadow-sm hover:opacity-90 active:scale-95 transition-all">
          <Save class="size-3.5" />
          Guardar
        </button>
      </div>
    </div>

    <!-- Employee Header Card -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex flex-col gap-0.5">
          <p class="text-lg font-semibold text-gray-900 dark:text-white">{workerName}</p>
          <p class="text-sm font-mono text-gray-500 dark:text-gray-400">{worker.cedulaIdentidad || "-"} — {worker.cargo || "Sin cargo"}</p>
        </div>
        <div class="w-px h-14 bg-gray-200 dark:bg-gray-700 hidden md:block"></div>
        <div class="ml-auto text-right">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 block mb-1">Salario Base</span>
          <p class="text-xl font-bold text-gray-900 dark:text-white font-mono">C${salBase}</p>
        </div>
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Ingresos -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <Plus class="size-4 text-green-600 dark:text-green-400" />
            Ingresos
          </h3>
        </div>
        <div class="space-y-3">
          <div>
            <label class="flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1" for="hrs_ext">
              Cant. horas ext
              <Info class="size-3 text-gray-400" title="Horas extras realizadas en el periodo" />
            </label>
            <input id="hrs_ext" type="text" value="12.5" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:border-gray-900 dark:focus:border-white focus:outline-none transition-all" />
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
            <input type="text" value="C$312.50" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
          </div>
          <div class="pt-3 border-t border-dashed border-gray-200 dark:border-gray-700">
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Ing. gravable</label>
            <input type="text" data-currency value="C$4,812.50" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white font-bold" />
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Ing. no gravable</label>
            <input type="text" data-currency value="C$0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
          </div>
        </div>
        <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-blue-800 dark:text-blue-300">Total ingresos</span>
          <span class="text-lg font-bold text-blue-800 dark:text-blue-300 font-mono">C$4,812.50</span>
        </div>
      </div>

      <!-- Deducciones -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm flex flex-col">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <Minus class="size-4 text-red-600 dark:text-red-400" />
            Deducciones
          </h3>
        </div>
        <div class="space-y-3 flex-1">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Cant. horas deducir</label>
              <input type="text" value="0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Deducciones varias</label>
            <input type="text" data-currency value="C$50.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">INSS</label>
              <input type="text" value="C$336.88" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-red-500 dark:text-red-400 font-bold cursor-not-allowed" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">IR</label>
              <input type="text" value="C$412.10" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-red-500 dark:text-red-400 font-bold cursor-not-allowed" />
            </div>
          </div>
        </div>
        <div class="mt-auto p-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-red-800 dark:text-red-300">Total deducciones</span>
          <span class="text-lg font-bold text-red-800 dark:text-red-300 font-mono">C$798.98</span>
        </div>
      </div>

      <!-- Otros / Subsidios -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm flex flex-col">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <DollarSign class="size-4 text-blue-600 dark:text-blue-400" />
            Otros / Subsidios
          </h3>
        </div>
        <div class="space-y-3 flex-1">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Cant. vac. desc</label>
              <input type="text" value="0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días sub. maternidad</label>
              <input type="text" value="0" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días Subsidio</label>
              <input type="text" value="0" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días laborados</label>
              <input type="text" value="15" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
          </div>
          <label class="flex items-center gap-2 mt-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer">
            <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white focus:ring-gray-900 dark:focus:ring-white" />
            <span class="text-xs font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300 cursor-pointer select-none">Reposo Laboral</span>
          </label>
        </div>
        <div class="mt-auto p-3 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-green-800 dark:text-green-300">Salario Ordinario</span>
          <span class="text-lg font-bold text-green-800 dark:text-green-300 font-mono">C${salBase}</span>
        </div>
      </div>
    </div>

    <!-- Summary Area -->
    <div class="bg-gray-900 dark:bg-gray-800 p-5 rounded-xl shadow-lg">
      <div class="flex justify-center items-center gap-4">
        <div class="text-center">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Salario Neto</span>
          <p class="text-3xl font-bold text-white font-mono">C$4,013.52</p>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<!-- Historial Modal -->
<Modal id="modal-historial" title="Historico de últimos 6 meses" size="lg">
  <div slot="body" class="space-y-4">
    <div class="overflow-x-auto">
      <table class="w-full" style="min-width:500px">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Período</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Salario</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {monthLabels.map((label) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">{label}</td>
              <td class="px-4 py-3 text-sm font-mono text-right text-gray-700 dark:text-gray-300">C${Number(salBaseNum).toFixed(2)}</td>
            </tr>
          ))}
          <tr class="bg-gray-50 dark:bg-gray-900 font-bold">
            <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">Promedio</td>
            <td class="px-4 py-3 text-sm font-mono text-right text-gray-900 dark:text-white">C${Number(salBaseNum).toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500">Salario base de C${salBase} replicado en todos los períodos.</p>
  </div>
  <div slot="footer">
    <button id="btn-historial-cerrar" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">Cerrar</button>
  </div>
</Modal>

<script>
  function parseCurrency(raw: string): number {
    return parseFloat(raw.replace(/[^0-9.]/g, "")) || 0;
  }

  document.querySelectorAll("[data-currency]").forEach((el) => {
    const input = el as HTMLInputElement;

    input.addEventListener("focus", function (this: HTMLInputElement) {
      this.classList.add("ring-2", "ring-gray-900", "dark:ring-white");
      const raw = parseCurrency(this.value);
      this.value = raw > 0 ? raw.toFixed(2) : "";
    });

    input.addEventListener("blur", function (this: HTMLInputElement) {
      this.classList.remove("ring-2", "ring-gray-900", "dark:ring-white");
      const raw = parseCurrency(this.value);
      this.value = raw > 0 ? "C$" + raw.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",") : "C$0.00";
    });

    input.addEventListener("input", function (this: HTMLInputElement) {
      const raw = this.value.replace(/[^0-9.]/g, "");
      const parts = raw.split(".");
      if (parts.length === 0 || parts[0] === undefined) { this.value = ""; return; }
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      this.value = parts.length > 1 ? parts[0] + "." + parts[1].slice(0, 2) : parts[0];
    });

    input.addEventListener("keydown", function (this: HTMLInputElement, e: KeyboardEvent) {
      if (e.key === "Backspace" || e.key === "Delete" || e.key === "Tab" || e.key === "ArrowLeft" || e.key === "ArrowRight" || e.key === "Home" || e.key === "End") return;
      if (!/[\d.]/.test(e.key) && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
      }
    });
  });

  // Regular text inputs  
  document.querySelectorAll('input[type="text"]:not([data-currency])').forEach((input) => {
    (input as HTMLInputElement).addEventListener("focus", function (this: HTMLInputElement) {
      this.classList.add("ring-2", "ring-gray-900", "dark:ring-white");
    });
    (input as HTMLInputElement).addEventListener("blur", function (this: HTMLInputElement) {
      this.classList.remove("ring-2", "ring-gray-900", "dark:ring-white");
    });
  });

  // Modal buttons
  document.getElementById("btn-historial")?.addEventListener("click", () => {
    (window as any).__openModal?.();
  });
  document.getElementById("btn-historial-cerrar")?.addEventListener("click", () => {
    (window as any).__closeModal?.();
  });
</script>

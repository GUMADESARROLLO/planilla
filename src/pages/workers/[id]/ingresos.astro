---
import AppLayout from "@components/layout/AppLayout.astro";
import Modal from "@components/ui/Modal.astro";
import { Save, Plus, Minus, DollarSign, Info, Clock } from "@lucide/astro";
import { db } from "@db/index";
import { trabajadores, cargos, tiposContrato } from "@db/schemas";
import { eq } from "drizzle-orm";

const idParam = Astro.params.id;
if (!idParam) return Astro.redirect("/workers");
const id = Number(idParam);

const worker = await db
  .select({
    id: trabajadores.id,
    nombre: trabajadores.nombre,
    apellidos: trabajadores.apellidos,
    cedulaIdentidad: trabajadores.cedulaIdentidad,
    cargo: cargos.nombre,
    tipoContrato: tiposContrato.nombre,
    salarioBase: trabajadores.salarioBase,
  })
  .from(trabajadores)
  .leftJoin(cargos, eq(trabajadores.cargoId, cargos.id))
  .leftJoin(tiposContrato, eq(trabajadores.tipoContratoId, tiposContrato.id))
  .where(eq(trabajadores.id, id))
  .limit(1)
  .then((r: any[]) => r[0]);

if (!worker) return Astro.redirect("/workers");

const currentPath = "/workers";
const title = `Ingresos y Deducciones - ${worker.nombre} ${worker.apellidos}`;
const salBase = Number(worker.salarioBase ?? 0).toLocaleString("es-NI", { minimumFractionDigits: 2 });
const workerName = `${worker.nombre} ${worker.apellidos}`;

// Generate last 6 month labels: May-19, Apr-19, ...
const monthLabels: string[] = [];
const now = new Date();
for (let i = 5; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const month = d.toLocaleDateString("en-US", { month: "short" });
  const year = String(d.getFullYear()).slice(-2);
  monthLabels.push(`${month}-${year}`);
}
const salBaseNum = Number(worker.salarioBase ?? 0);
---

<AppLayout {title} {currentPath}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-end gap-4">
      <div>
        <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">Payroll &gt; Processing</span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">Employee Payroll Detail</h1>
      </div>
      <div class="flex gap-2">
        <button id="btn-historial" type="button" class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
          <Clock class="size-3.5" />
          Historial
        </button>
        <a href={`/workers/${id}`} class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider border border-gray-300 dark:border-gray-600 rounded-lg text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all">
          Cancelar
        </a>
        <button id="btn-guardar" class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-bold uppercase tracking-wider bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg shadow-sm hover:opacity-90 active:scale-95 transition-all">
          <Save class="size-3.5" />
          Guardar
        </button>
      </div>
    </div>

    <!-- Employee Header Card -->
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-5 shadow-sm">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex flex-col gap-0.5">
          <p class="text-lg font-semibold text-gray-900 dark:text-white">{workerName}</p>
          <p class="text-sm font-mono text-gray-500 dark:text-gray-400">{worker.cedulaIdentidad || "-"} — {worker.cargo || "Sin cargo"}</p>
        </div>
        <div class="w-px h-14 bg-gray-200 dark:bg-gray-700 hidden md:block"></div>
        <div class="ml-auto text-right">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 block mb-1">Salario Base</span>
          <p class="text-xl font-bold text-gray-900 dark:text-white font-mono">C${salBase}</p>
        </div>
      </div>
    </div>

    <!-- Main Grid -->
    <input id="salario_base_val" type="hidden" value={worker.salarioBase ?? 0} />
    <input id="page-planilla-id" type="hidden" value="" />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Ingresos -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <Plus class="size-4 text-green-600 dark:text-green-400" />
            Ingresos
          </h3>
        </div>
        <div class="space-y-3">
          <div>
            <label class="flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1" for="hrs_ext">
              Cant. horas ext
              <Info class="size-3 text-gray-400" title="Horas extras realizadas en el periodo" />
            </label>
            <input id="hrs_ext" type="text" value="12.5" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:border-gray-900 dark:focus:border-white focus:outline-none transition-all" />
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
            <input id="monto_hrs_extras" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
          </div>
          <div class="pt-3 border-t border-dashed border-gray-200 dark:border-gray-700">
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Ing. gravable</label>
            <input id="ing_gravable" type="text" data-currency value="C$0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white font-bold" />
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Ing. no gravable</label>
            <input id="ing_no_gravable" type="text" data-currency value="C$0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
          </div>
        </div>
        <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-blue-800 dark:text-blue-300">Total ingresos</span>
          <span id="total_ingresos" class="text-lg font-bold text-blue-800 dark:text-blue-300 font-mono">C$0.00</span>
        </div>
      </div>

      <!-- Deducciones -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm flex flex-col">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <Minus class="size-4 text-red-600 dark:text-red-400" />
            Deducciones
          </h3>
        </div>
        <div class="space-y-3 flex-1">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Cant. horas deducir</label>
              <input id="hrs_deducir" type="text" inputmode="numeric" value="0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input id="monto_hrs_deducir" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div>
            <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Deducciones varias</label>
            <input id="deduc_varias" type="text" data-currency value="C$0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">INSS</label>
              <input id="inss" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-red-500 dark:text-red-400 font-bold cursor-not-allowed" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">IR</label>
              <input id="ir" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-red-500 dark:text-red-400 font-bold cursor-not-allowed" />
            </div>
          </div>
        </div>
        <div class="mt-auto p-3 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-red-800 dark:text-red-300">Total deducciones</span>
          <span id="total_deducciones" class="text-lg font-bold text-red-800 dark:text-red-300 font-mono">C$0.00</span>
        </div>
      </div>

      <!-- Otros / Subsidios -->
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl p-4 shadow-sm flex flex-col">
        <div class="flex items-center justify-between pb-3 mb-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold flex items-center gap-1.5 text-gray-900 dark:text-white">
            <DollarSign class="size-4 text-blue-600 dark:text-blue-400" />
            Otros / Subsidios
          </h3>
        </div>
        <div class="space-y-3 flex-1">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Cant. vac. desc</label>
              <input id="dias_descansados" type="text" value="0.00" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input id="monto_descansados" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días sub. maternidad</label>
              <input id="dias_sub_maternidad" type="text" inputmode="numeric" value="0" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Monto</label>
              <input id="monto_sub_maternidad" type="text" value="C$0.00" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-not-allowed" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días Subsidio</label>
              <input id="dias_subsidio" type="text" inputmode="numeric" value="0" class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 block">Días laborados</label>
              <input id="dias_laborados" type="text" value="15" readonly class="w-full px-3 py-2 text-sm font-mono text-right border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white cursor-not-allowed" />
            </div>
          </div>
          <label class="flex items-center gap-2 mt-3 px-2 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer">
            <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white focus:ring-gray-900 dark:focus:ring-white" />
            <span class="text-xs font-bold uppercase tracking-wider text-gray-700 dark:text-gray-300 cursor-pointer select-none">Reposo Laboral</span>
          </label>
        </div>
        <div class="mt-auto p-3 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-900 rounded-lg flex justify-between items-center">
          <span class="text-xs font-bold uppercase tracking-wider text-green-800 dark:text-green-300">Salario Ordinario</span>
          <span id="salario_ordinario" class="text-lg font-bold text-green-800 dark:text-green-300 font-mono">C$0.00</span>
        </div>
      </div>
    </div>

    <!-- Summary Area -->
    <div class="bg-gray-900 dark:bg-gray-800 p-5 rounded-xl shadow-lg">
      <div class="flex justify-center items-center gap-4">
        <div class="text-center">
          <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Salario Neto</span>
          <p id="salario_neto" class="text-3xl font-bold text-white font-mono">C$0.00</p>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<!-- Historial Modal -->
<Modal id="modal-historial" title="Historico de últimos 6 meses" size="lg">
  <div slot="body" class="space-y-4">
    <div class="overflow-x-auto">
      <table class="w-full" style="min-width:500px">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Período</th>
            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Salario</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {monthLabels.map((label) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">{label}</td>
              <td class="px-4 py-3 text-sm font-mono text-right text-gray-700 dark:text-gray-300">C${Number(salBaseNum).toFixed(2)}</td>
            </tr>
          ))}
          <tr class="bg-gray-50 dark:bg-gray-900 font-bold">
            <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">Promedio</td>
            <td class="px-4 py-3 text-sm font-mono text-right text-gray-900 dark:text-white">C${Number(salBaseNum).toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-500">Salario base de C${salBase} replicado en todos los períodos.</p>
  </div>
  <div slot="footer">
    <button id="btn-historial-cerrar" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">Cerrar</button>
  </div>
</Modal>

<script>
  const salBase = parseFloat(document.getElementById("salario_base_val")?.value || "0");
  const VALOR_HORA = salBase / 30 / 8;
  const workerId = Number(window.location.pathname.match(/\/workers\/(\d+)/)?.[1]);
  const urlParams = new URLSearchParams(window.location.search);
  const planillaId = Number(urlParams.get("planillaId"));

  if (planillaId) document.getElementById("page-planilla-id").value = String(planillaId);

  function n(v) { return parseFloat(String(v).replace(/[^0-9.-]/g, "")) || 0; }

  function fmt(v) { return "C$" + v.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ","); }

  function fmtRaw(v) { return v.toFixed(2); }

  function calcIR(rentaGravableQ) {
    const anual = rentaGravableQ * 24;
    if (anual <= 100000) return 0;
    if (anual <= 200000) return (anual - 100000) * 0.15 / 24;
    if (anual <= 350000) return (15000 + (anual - 200000) * 0.20) / 24;
    if (anual <= 500000) return (45000 + (anual - 350000) * 0.25) / 24;
    return (82500 + (anual - 500000) * 0.30) / 24;
  }

  function numericFilter(e) {
    const allowed = ["Backspace","Delete","Tab","ArrowLeft","ArrowRight","ArrowUp","ArrowDown","Home","End","Enter"];
    if (allowed.includes(e.key) || e.ctrlKey || e.metaKey) return;
    if (!/[\d.]/.test(e.key)) e.preventDefault();
  }

  function getValues() {
    const dd = n(document.getElementById("dias_descansados")?.value);
    const dl = Math.max(0, 15 - dd);
    const montoDesc = VALOR_HORA * 8 * dd;
    const salOrd = VALOR_HORA * 8 * dl;
    const hrsExt = n(document.getElementById("hrs_ext")?.value);
    const hrsMonto = hrsExt * VALOR_HORA * 2;
    const ingGrav = n(document.getElementById("ing_gravable")?.value);
    const ingNoGrav = n(document.getElementById("ing_no_gravable")?.value);
    const subMatDias = n(document.getElementById("dias_sub_maternidad")?.value);
    const subMatMonto = subMatDias * VALOR_HORA * 8;
    const subEstDias = n(document.getElementById("dias_subsidio")?.value);
    const subEstMonto = subEstDias * VALOR_HORA * 8;
    const totalIngreso = salOrd + hrsMonto + ingGrav + ingNoGrav + montoDesc + subMatMonto + subEstMonto;

    const hrsDed = n(document.getElementById("hrs_deducir")?.value);
    const montoHrsDed = hrsDed * VALOR_HORA;
    const deducV = n(document.getElementById("deduc_varias")?.value);
    const TOPE_INSS_Q = 3389.45;
    const inss = Math.min(totalIngreso * 0.07, TOPE_INSS_Q);
    const rentaGravableQ = totalIngreso - inss;
    const ir = calcIR(rentaGravableQ);
    const totalDed = inss + ir + montoHrsDed + deducV;
    const neto = Math.max(0, totalIngreso - totalDed);

    return {
      ingresos: {
        salarioOrdinario: salOrd,
        hrsExtras: hrsExt,
        montoHrsExtras: hrsMonto,
        ingresoGravable: ingGrav,
        ingresoNoGravable: ingNoGrav,
      },
      subsidios: {
        diasVacDescanso: dd,
        montoVacDescanso: montoDesc,
        diasSubMaternidad: subMatDias,
        montoSubMaternidad: subMatMonto,
        diasSubsidio: subEstDias,
        montoSubEstatal: subEstMonto,
        diasLaborados: dl,
      },
      deducciones: {
        hrsDeducir: hrsDed,
        montoHrsDeducir: montoHrsDed,
        inssLaboral: inss,
        ir: ir,
        deducVarias: deducV,
      },
      totales: {
        totalIngreso,
        totalDeducciones: totalDed,
        netoPagar: neto,
      },
    };
  }

  function updateUI(v) {
    document.getElementById("dias_laborados").value = fmtRaw(v.subsidios.diasLaborados);
    document.getElementById("monto_descansados").value = fmt(v.subsidios.montoVacDescanso);
    document.getElementById("monto_hrs_extras").value = fmt(v.ingresos.montoHrsExtras);
    document.getElementById("salario_ordinario").textContent = fmt(v.ingresos.salarioOrdinario);
    document.getElementById("monto_hrs_deducir").value = fmt(v.deducciones.montoHrsDeducir);
    document.getElementById("inss").value = fmt(v.deducciones.inssLaboral);
    document.getElementById("ir").value = fmt(v.deducciones.ir);
    document.getElementById("total_ingresos").textContent = fmt(v.totales.totalIngreso);
    document.getElementById("total_deducciones").textContent = fmt(v.totales.totalDeducciones);
    document.getElementById("salario_neto").textContent = fmt(v.totales.netoPagar);
  }

  function recalc() { updateUI(getValues()); }

  // Load saved data
  async function loadSaved() {
    if (!planillaId) return;
    try {
      const res = await fetch(`/api/workers/${workerId}/ingresos?planillaId=${planillaId}`);
      const json = await res.json();
      if (!json.success || !json.data) return;

      const d = json.data;
      if (d.hrsExtras) document.getElementById("hrs_ext").value = d.hrsExtras;
      if (d.ingresoGravable) document.getElementById("ing_gravable").value = "C$" + Number(d.ingresoGravable).toFixed(2);
      if (d.ingresoNoGravable) document.getElementById("ing_no_gravable").value = "C$" + Number(d.ingresoNoGravable).toFixed(2);
      if (d.diasVacDescanso) document.getElementById("dias_descansados").value = d.diasVacDescanso;
      if (d.diasSubMaternidad) document.getElementById("dias_sub_maternidad").value = d.diasSubMaternidad;
      if (d.diasSubsidio) document.getElementById("dias_subsidio").value = d.diasSubsidio;
      if (d.hrsDeducir) document.getElementById("hrs_deducir").value = d.hrsDeducir;
      if (d.deducVarias) document.getElementById("deduc_varias").value = "C$" + Number(d.deducVarias).toFixed(2);
      recalc();
    } catch {}
  }

  // Save handler
  document.getElementById("btn-guardar")?.addEventListener("click", async () => {
    if (!planillaId) { alert("No hay planilla seleccionada"); return; }

    const btn = document.getElementById("btn-guardar");
    btn.textContent = "Guardando...";
    btn.disabled = true;

    const v = getValues();
    const payload = { ...v.ingresos, ...v.subsidios, ...v.deducciones, ...v.totales };

    try {
      const res = await fetch(`/api/workers/${workerId}/ingresos?planillaId=${planillaId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (!json.success) throw new Error(json.error?.message || "Error");
      const Toast = (await import("sweetalert2")).default;
      Toast.fire({ icon: "success", title: "Guardado", timer: 1000, showConfirmButton: false });
    } catch (err) {
      const Toast = (await import("sweetalert2")).default;
      Toast.fire({ icon: "error", title: err.message || "Error al guardar" });
    } finally {
      btn.textContent = "Guardar";
      btn.disabled = false;
    }
  });

  // Attach events
  ["dias_descansados","dias_sub_maternidad","dias_subsidio","hrs_ext","hrs_deducir"].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener("input", recalc);
    el.addEventListener("keydown", numericFilter);
  });

  ["ing_gravable","ing_no_gravable","deduc_varias"].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener("input", recalc);
  });

  recalc();

  // Currency mask
  document.querySelectorAll("[data-currency]").forEach((el) => {
    el.addEventListener("blur", function () {
      const raw = n(this.value);
      this.value = raw > 0 ? "C$" + raw.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",") : "C$0.00";
    });
  });

  // Load saved data after init
  loadSaved();

  // Historial modal
  document.getElementById("btn-historial")?.addEventListener("click", () => (window).__openModal?.());
  document.getElementById("btn-historial-cerrar")?.addEventListener("click", () => (window).__closeModal?.());
</script>

---
import { X } from "@lucide/astro";

export interface Props {
  open?: boolean;
  title?: string;
  size?: "sm" | "md" | "lg" | "xl";
  onClose?: string;
  class?: string;
  id?: string;
}

const { open = false, title, size = "md", class: className = "", id } = Astro.props;
const prefix = id ?? "modal";

const sizeClasses: Record<string, string> = {
  sm: "max-w-sm",
  md: "max-w-lg",
  lg: "max-w-2xl",
  xl: "max-w-4xl",
};
---

<div
  id={`${prefix}-overlay`}
  data-prefix={prefix}
  class:list={[
    "fixed inset-0 z-[60] flex items-center justify-center p-4",
    open ? "" : "hidden",
  ]}
  aria-modal="true"
  role="dialog"
  aria-labelledby={title ? `${prefix}-title` : undefined}
>
  <!-- Backdrop -->
  <div
    id={`${prefix}-backdrop`}
    class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm"
  ></div>

  <!-- Dialog -->
  <div
    id={`${prefix}-dialog`}
    class={[
      "relative w-full bg-white dark:bg-gray-900 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-800",
      "transform transition-all duration-200 scale-95 opacity-0",
      open ? "scale-100 opacity-100" : "",
      sizeClasses[size] ?? sizeClasses.md,
      className,
    ].filter(Boolean).join(" ")}
  >
    <!-- Header -->
    {title && (
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-800">
        <h2 id={`${prefix}-title`} class="text-lg font-semibold text-gray-900 dark:text-white">{title}</h2>
        <button
          id={`${prefix}-close`}
          type="button"
          class="p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 transition-colors"
          aria-label="Cerrar"
        >
          <X class="size-5" />
        </button>
      </div>
    )}

    <!-- Body -->
    <div class="px-6 py-4 overflow-y-auto max-h-[70vh]">
      <slot name="body">
        <slot />
      </slot>
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950/50 rounded-b-xl">
      <slot name="footer" />
    </div>
  </div>
</div>

<script>
  const instances: Array<{ overlay: HTMLElement; dialog: HTMLElement; backdrop: HTMLElement; closeBtn: HTMLElement | null }> = [];

  document.querySelectorAll<HTMLElement>("[data-prefix]").forEach((overlay) => {
    const prefix = overlay.dataset.prefix ?? "modal";
    const dialog = document.getElementById(`${prefix}-dialog`)!;
    const backdrop = document.getElementById(`${prefix}-backdrop`)!;
    const closeBtn = document.getElementById(`${prefix}-close`);

    if (!dialog || !backdrop) return;

    function closeModal() {
      dialog.classList.remove("scale-100", "opacity-100");
      dialog.classList.add("scale-95", "opacity-0");
      setTimeout(() => overlay.classList.add("hidden"), 150);
    }

    function openModal() {
      overlay.classList.remove("hidden");
      void dialog.offsetWidth;
      dialog.classList.remove("scale-95", "opacity-0");
      dialog.classList.add("scale-100", "opacity-100");
    }

    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    backdrop.addEventListener("click", closeModal);

    // Expose scoped open/close on the overlay element
    (overlay as any).__modalOpen = openModal;
    (overlay as any).__modalClose = closeModal;

    // Focus trap
    overlay.addEventListener("keydown", (e) => {
      if (e.key === "Tab") {
        const focusable = dialog.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        if (focusable.length === 0) return;
        const first = focusable[0]!;
        const last = focusable[focusable.length - 1]!;
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Auto-focus first focusable element on open
    const observer = new MutationObserver(() => {
      if (!overlay.classList.contains("hidden")) {
        const first = dialog.querySelector<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        first?.focus();
      }
    });
    observer.observe(overlay, { attributes: true, attributeFilter: ["class"] });

    instances.push({ overlay, dialog, backdrop, closeBtn });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      instances.forEach(({ overlay, dialog }) => {
        if (!overlay.classList.contains("hidden")) {
          dialog.classList.remove("scale-100", "opacity-100");
          dialog.classList.add("scale-95", "opacity-0");
          setTimeout(() => overlay.classList.add("hidden"), 150);
        }
      });
    }
  });

  // Legacy global access (for first modal, backward compat)
  if (instances.length > 0) {
    (window as any).__openModal = instances[0].overlay.__modalOpen;
    (window as any).__closeModal = instances[0].overlay.__modalClose;
  }
</script>

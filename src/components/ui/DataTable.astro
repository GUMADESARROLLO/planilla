---
import { ArrowUpDown, ArrowUp, ArrowDown, Search, ChevronLeft, ChevronRight, Loader2 } from "@lucide/astro";

export interface Column {
  key: string;
  label: string;
  sortable?: boolean;
  render?: (value: any, row: any) => string;
}

export interface Meta {
  page: number;
  totalPages: number;
  total: number;
  limit: number;
}

export interface Props {
  columns: Column[];
  data: any[];
  meta?: Meta;
  loading?: boolean;
  sortKey?: string;
  sortDir?: "asc" | "desc";
  searchValue?: string;
  onPageChange?: string;
  onSort?: string;
  onSearch?: string;
  class?: string;
}

const {
  columns,
  data,
  meta,
  loading = false,
  sortKey,
  sortDir,
  searchValue = "",
  class: className = "",
} = Astro.props;

function getSortIcon(key: string): string {
  if (sortKey !== key) return "ArrowUpDown";
  return sortDir === "asc" ? "ArrowUp" : "ArrowDown";
}
---

<div class={className}>
  <!-- Search -->
  <div class="flex items-center gap-3 mb-4">
    <div class="relative flex-1 max-w-xs">
      <Search class="absolute left-3 top-1/2 -translate-y-1/2 size-4 text-gray-400 pointer-events-none" />
      <input
        id="datatable-search"
        type="text"
        value={searchValue}
        placeholder="Buscar..."
        class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
        aria-label="Buscar en la tabla"
      />
    </div>
    {meta && (
      <p class="text-sm text-gray-500 dark:text-gray-400 ml-auto">
        Mostrando {data.length > 0 ? (meta.page - 1) * meta.limit + 1 : 0} - {Math.min(meta.page * meta.limit, meta.total)} de {meta.total}
      </p>
    )}
  </div>

  <!-- Table -->
  <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
      <thead class="bg-gray-50 dark:bg-gray-900">
        <tr>
          {columns.map((col) => (
            <th
              key={col.key}
              class:list={[
                "px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider",
                col.sortable ? "cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300" : "",
              ]}
              data-sort-key={col.sortable ? col.key : undefined}
              scope="col"
            >
              <div class="flex items-center gap-1.5">
                {col.label}
                {col.sortable && (
                  <span class="text-gray-300 dark:text-gray-600">
                    {getSortIcon(col.key) === "ArrowUpDown" && <ArrowUpDown class="size-3.5" />}
                    {getSortIcon(col.key) === "ArrowUp" && <ArrowUp class="size-3.5 text-primary-600" />}
                    {getSortIcon(col.key) === "ArrowDown" && <ArrowDown class="size-3.5 text-primary-600" />}
                  </span>
                )}
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-100 dark:divide-gray-800">
        {loading ? (
          Array.from({ length: 5 }).map(() => (
            <tr>
              {columns.map((col) => (
                <td key={col.key} class="px-4 py-3">
                  <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded animate-pulse w-3/4"></div>
                </td>
              ))}
            </tr>
          ))
        ) : data.length === 0 ? (
          <tr>
            <td colspan={columns.length} class="px-4 py-12 text-center">
              <div class="flex flex-col items-center gap-2 text-gray-400 dark:text-gray-500">
                <InboxIcon class="size-10" />
                <p class="text-sm font-medium">No se encontraron registros</p>
                <p class="text-xs">Intente ajustar su búsqueda o filtros.</p>
              </div>
            </td>
          </tr>
        ) : (
          data.map((row, i) => (
            <tr key={row.id ?? i} class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              {columns.map((col) => (
                <td key={col.key} class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  {col.render ? col.render(row[col.key], row) : (row[col.key] ?? "-")}
                </td>
              ))}
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  {meta && meta.totalPages > 1 && (
    <div class="flex items-center justify-between mt-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Página {meta.page} de {meta.totalPages}
      </p>
      <div class="flex items-center gap-1">
        <button
          id="datatable-prev"
          class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 disabled:opacity-30 disabled:pointer-events-none transition-colors"
          aria-label="Página anterior"
          type="button"
        >
          <ChevronLeft class="size-4" />
        </button>
        {Array.from({ length: meta.totalPages }, (_, i) => i + 1)
          .filter((p) => p === 1 || p === meta.totalPages || Math.abs(p - meta.page) <= 1)
          .map((p, idx, arr) => (
            <>
              {idx > 0 && arr[idx - 1] !== p - 1 && (
                <span class="px-2 text-gray-400 text-sm">...</span>
              )}
              <button
                data-page={p}
                class:list={[
                  "min-w-[2rem] h-8 rounded-lg text-sm font-medium transition-colors",
                  p === meta!.page
                    ? "bg-primary-600 text-white"
                    : "text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800",
                ]}
                type="button"
              >
                {p}
              </button>
            </>
          ))}
        <button
          id="datatable-next"
          class="p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800 disabled:opacity-30 disabled:pointer-events-none transition-colors"
          aria-label="Página siguiente"
          type="button"
        >
          <ChevronRight class="size-4" />
        </button>
      </div>
    </div>
  )}
</div>

<script>
  import { Inbox } from "@lucide/astro";

  const searchInput = document.getElementById("datatable-search") as HTMLInputElement;
  let searchTimeout: ReturnType<typeof setTimeout>;

  if (searchInput) {
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const event = new CustomEvent("datatable-search", { detail: { value: searchInput.value } });
        document.dispatchEvent(event);
      }, 300);
    });
  }

  document.querySelectorAll("[data-sort-key]").forEach((th) => {
    th.addEventListener("click", () => {
      const key = th.getAttribute("data-sort-key")!;
      const event = new CustomEvent("datatable-sort", { detail: { key } });
      document.dispatchEvent(event);
    });
  });

  document.querySelectorAll("[data-page]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const page = parseInt(btn.getAttribute("data-page")!, 10);
      const event = new CustomEvent("datatable-page", { detail: { page } });
      document.dispatchEvent(event);
    });
  });

  const prevBtn = document.getElementById("datatable-prev");
  const nextBtn = document.getElementById("datatable-next");

  prevBtn?.addEventListener("click", () => {
    const event = new CustomEvent("datatable-page", { detail: { page: "prev" } });
    document.dispatchEvent(event);
  });

  nextBtn?.addEventListener("click", () => {
    const event = new CustomEvent("datatable-page", { detail: { page: "next" } });
    document.dispatchEvent(event);
  });
</script>

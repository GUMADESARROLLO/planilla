---
export interface Props {
  variant?: "success" | "warning" | "danger" | "info" | "default";
  size?: "sm" | "md";
  class?: string;
}

const { variant = "default", size = "sm", class: className = "" } = Astro.props;

const variantClasses: Record<string, string> = {
  success: "bg-success-50 text-success-700 ring-success-600/20 dark:bg-success-950 dark:text-success-400 dark:ring-success-500/30",
  warning: "bg-warning-50 text-warning-700 ring-warning-600/20 dark:bg-warning-950 dark:text-warning-400 dark:ring-warning-500/30",
  danger: "bg-danger-50 text-danger-700 ring-danger-600/20 dark:bg-danger-950 dark:text-danger-400 dark:ring-danger-500/30",
  info: "bg-info-50 text-info-700 ring-info-600/20 dark:bg-info-950 dark:text-info-400 dark:ring-info-500/30",
  default: "bg-gray-100 text-gray-700 ring-gray-600/20 dark:bg-gray-800 dark:text-gray-300 dark:ring-gray-500/30",
};

const sizeClasses: Record<string, string> = {
  sm: "px-1.5 py-0.5 text-xs",
  md: "px-2.5 py-1 text-sm",
};

const classes = [
  "inline-flex items-center font-medium rounded-md ring-1 ring-inset",
  variantClasses[variant] ?? variantClasses.default,
  sizeClasses[size] ?? sizeClasses.sm,
  className,
].filter(Boolean).join(" ");
---

<span class={classes}>
  <slot />
</span>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import Sidebar from "@components/layout/Sidebar.astro";
import Navbar from "@components/layout/Navbar.astro";

export interface Props {
  title: string;
  currentPath: string;
}

const { title, currentPath } = Astro.props;
---

<BaseLayout {title}>
  <div class="min-h-screen flex bg-gray-50 dark:bg-gray-950">
    <Sidebar {currentPath} />
    <div id="main-content" class="flex-1 flex flex-col min-h-screen bg-gray-50 dark:bg-gray-950">
      <Navbar pageTitle={title} />
      <main class="flex-1 p-4 lg:p-6 overflow-auto bg-gray-50 dark:bg-gray-950">
        <slot />
      </main>
      <footer class="border-t border-gray-200 dark:border-gray-800 px-6 py-3">
        <p class="text-xs text-gray-400 dark:text-gray-500 text-center">
          &copy; {new Date().getFullYear()} Plan-IA. Todos los derechos reservados.
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>



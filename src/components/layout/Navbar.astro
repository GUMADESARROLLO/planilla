---
import { Menu, Bell, Search, LogOut, User, ChevronDown } from "@lucide/astro";

export interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;
const user = Astro.locals.user;
---

<header class="sticky top-0 z-30 h-16 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 flex items-center justify-between px-4 lg:px-6">
  <!-- Left: Mobile menu toggle + page title -->
  <div class="flex items-center gap-3">
    <button
      id="navbar-menu-toggle"
      class="lg:hidden p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800"
      aria-label="Abrir menú"
      type="button"
    >
      <Menu class="size-5" />
    </button>
    <h1 class="text-lg font-semibold text-gray-900 dark:text-white truncate">{pageTitle}</h1>
  </div>

  <!-- Right: Search, notifications, user -->
  <div class="flex items-center gap-2">
    <!-- Search (desktop) -->
    <button
      class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm text-gray-400 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-colors"
      aria-label="Buscar"
      type="button"
    >
      <Search class="size-4" />
      <span>Buscar...</span>
      <kbd class="hidden md:inline-flex px-1.5 py-0.5 text-xs rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-400">Ctrl+K</kbd>
    </button>

    <!-- Notifications -->
    <button
      class="relative p-2 rounded-lg text-gray-500 hover:text-gray-700 hover:bg-gray-100 dark:hover:text-gray-300 dark:hover:bg-gray-800"
      aria-label="Notificaciones"
      type="button"
    >
      <Bell class="size-5" />
      <span class="absolute top-1.5 right-1.5 size-2 rounded-full bg-danger-500 ring-2 ring-white dark:ring-gray-900"></span>
    </button>

    <!-- User dropdown -->
    <div id="user-dropdown" class="relative">
      <button
        id="user-menu-button"
        class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        aria-label="Menú de usuario"
        aria-haspopup="true"
        aria-expanded="false"
        type="button"
      >
        <div class="size-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center text-primary-700 dark:text-primary-300 font-semibold text-sm">
          {user?.name ? user.name.charAt(0).toUpperCase() + (user.name.split(" ")[1]?.charAt(0) ?? "") : "U"}
        </div>
        <div class="hidden md:block text-left">
          <p class="text-sm font-medium text-gray-900 dark:text-white leading-tight">{user?.name ?? "Usuario"}</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">{user?.email ?? ""}</p>
        </div>
        <ChevronDown class="hidden md:block size-4 text-gray-400" />
      </button>

      <!-- Dropdown menu -->
      <div
        id="user-dropdown-menu"
        class="absolute right-0 top-full mt-1 w-56 bg-white dark:bg-gray-800 rounded-lg shadow-lg shadow-gray-200/50 dark:shadow-black/30 border border-gray-200 dark:border-gray-700 py-1 opacity-0 invisible translate-y-1 transition-all duration-200 z-50"
        role="menu"
        aria-orientation="vertical"
      >
        <a
          href="/profile"
          class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700/50"
          role="menuitem"
        >
          <User class="size-4 text-gray-400" />
          Mi Perfil
        </a>
        <hr class="border-gray-200 dark:border-gray-700 my-1" />
        <a
          href="/logout"
          class="flex items-center gap-3 px-4 py-2.5 text-sm text-danger-600 dark:text-danger-400 hover:bg-danger-50 dark:hover:bg-danger-950/50"
          role="menuitem"
        >
          <LogOut class="size-4" />
          Cerrar sesión
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("navbar-menu-toggle")!;
  const userMenuButton = document.getElementById("user-menu-button")!;
  const userMenu = document.getElementById("user-dropdown-menu")!;

  menuToggle.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("toggle-sidebar"));
  });

  userMenuButton.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = userMenu.classList.contains("opacity-0");
    if (isOpen) {
      userMenu.classList.remove("opacity-0", "invisible", "translate-y-1");
      userMenu.classList.add("opacity-100", "visible", "translate-y-0");
      userMenuButton.setAttribute("aria-expanded", "true");
    } else {
      closeDropdown();
    }
  });

  function closeDropdown() {
    userMenu.classList.add("opacity-0", "invisible", "translate-y-1");
    userMenu.classList.remove("opacity-100", "visible", "translate-y-0");
    userMenuButton.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", (e) => {
    if (!document.getElementById("user-dropdown")?.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDropdown();
  });
</script>

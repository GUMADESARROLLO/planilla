# Database
DATABASE_URL=mysql://root:root@localhost:3306/planilla_hr
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=planilla_hr
DB_PORT=3306
DB_POOL_LIMIT=10

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
